# 本地开发配置模板
# 复制此文件为 application-local.yml 并填入真实值
# application-local.yml 已加入 .gitignore，不会被提交

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/qianxing_zhidao?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
    username: root
    password: your_db_password_here

# 微信小程序配置
wx:
  appid: your_wx_appid_here
  secret: your_wx_secret_here

# JWT 配置
jwt:
  secret: your_jwt_secret_here_at_least_256_bits

# 大模型配置（可选，暂不接真实 LLM）
llm:
  api-base-url: https://api.example.com/v1
  api-key: your_llm_api_key_here
  model: gpt-4

# 天气 API 配置（可选）
weather:
  api-base-url: https://api.example.com/weather
  api-key: your_weather_api_key_here
  provider: example_provider
  update-enabled: false
