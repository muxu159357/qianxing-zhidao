/* 全局样式 - 黔行智导小程序 · Stitch 自然科技风 */

page {
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  background: #f8f9fa;
  box-sizing: border-box;
  color: #012d1d;
}

/* ===== Color system (Stitch) ===== */
.c-primary { color: #012d1d; }
.c-green { color: #116c4a; }
.c-mint { color: #a1f4c8; }
.c-text { color: #012d1d; }
.c-gray { color: #414844; }
.c-hint { color: #8a9ba6; }
.c-white { color: #ffffff; }

.bg-primary { background: #012d1d; }
.bg-green { background: #116c4a; }
.bg-mint { background: #a1f4c8; }
.bg-light-green { background: #c1ecd4; }
.bg-light-gray { background: #f3f4f5; }
.bg-page { background: #f8f9fa; }

/* ===== Page shell ===== */
.page-shell {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

/* ===== App header ===== */
.app-header {
  padding: 40rpx 32rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.app-header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #012d1d;
  letter-spacing: 2rpx;
}
.app-header-sub {
  font-size: 24rpx;
  color: #414844;
  margin-top: 4rpx;
}

/* ===== Section title ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #012d1d;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #116c4a;
  line-height: 1.3;
}

/* ===== Surface card ===== */
.surface-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 40rpx rgba(1, 45, 29, 0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* ===== Hero card ===== */
.hero-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin: 0 24rpx;
}
.hero-card-image {
  width: 100%;
  height: 400rpx;
  display: block;
}
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(1,45,29,0.15) 0%, rgba(1,45,29,0.65) 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 36rpx;
}
.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 8rpx;
}
.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

/* ===== Primary button ===== */
.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: #012d1d;
  color: #ffffff;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(1, 45, 29, 0.2);
}
.primary-button:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.primary-button::after {
  border: none;
}

/* ===== Secondary button ===== */
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #c1ecd4;
  color: #012d1d;
  border: none;
}
.secondary-button:active {
  transform: scale(0.97);
  opacity: 0.85;
}
.secondary-button::after {
  border: none;
}

/* ===== Outline button ===== */
.outline-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: transparent;
  color: #116c4a;
  border: 2rpx solid #c1c8c2;
}
.outline-button:active {
  background: #f3f4f5;
  transform: scale(0.97);
}

/* ===== Tag chip ===== */
.tag-chip {
  display: inline-block;
  font-size: 22rpx;
  color: #116c4a;
  background: #c1ecd4;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

/* ===== Status chip ===== */
.status-chip {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}
.status-chip-upcoming {
  color: #116c4a;
  background: #c1ecd4;
}
.status-chip-active {
  color: #e67e22;
  background: rgba(230,126,34,0.12);
}
.status-chip-completed {
  color: #414844;
  background: #edeeef;
}

/* ===== Ambient shadow ===== */
.ambient-shadow {
  box-shadow: 0 8rpx 40rpx rgba(1, 45, 29, 0.05);
}

/* ===== Horizontal scroll ===== */
.horizontal-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}
.horizontal-scroll-item {
  display: inline-block;
  margin-right: 16rpx;
  vertical-align: top;
}

/* ===== Route card (list) ===== */
.route-card {
  display: flex;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(1, 45, 29, 0.05);
}
.route-card-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.route-card-thumb image {
  width: 100%;
  height: 100%;
}
.route-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.route-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #012d1d;
  margin-bottom: 6rpx;
}
.route-card-meta {
  font-size: 22rpx;
  color: #116c4a;
  margin-bottom: 6rpx;
}
.route-card-desc {
  font-size: 22rpx;
  color: #414844;
  line-height: 1.4;
}

/* ===== Scenic card (grid) ===== */
.scenic-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(1, 45, 29, 0.05);
}
.scenic-card-image {
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}
.scenic-card-image image {
  width: 100%;
  height: 100%;
}
.scenic-card-body {
  padding: 16rpx 20rpx 20rpx;
}
.scenic-card-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #012d1d;
  margin-bottom: 4rpx;
}
.scenic-card-city {
  font-size: 22rpx;
  color: #8a9ba6;
  margin-bottom: 8rpx;
}

/* ===== Timeline ===== */
.timeline {
  padding: 0;
}
.timeline-node {
  display: flex;
  gap: 18rpx;
  padding-bottom: 4rpx;
}
.timeline-marker {
  width: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.timeline-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #116c4a;
  margin-top: 8rpx;
  box-shadow: 0 0 0 6rpx rgba(17,108,74,0.1);
}
.timeline-line {
  width: 3rpx;
  flex: 1;
  background: rgba(17,108,74,0.14);
  margin-top: 8rpx;
}
.timeline-card {
  flex: 1;
  padding: 14rpx 22rpx 26rpx;
  margin-bottom: 8rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 40rpx rgba(1, 45, 29, 0.05);
}
.timeline-head {
  font-size: 28rpx;
  font-weight: 700;
  color: #116c4a;
  margin-bottom: 8rpx;
}
.timeline-desc {
  font-size: 26rpx;
  color: #414844;
  line-height: 1.65;
  margin-bottom: 10rpx;
}
.timeline-meta {
  font-size: 22rpx;
  color: #8a9ba6;
}

/* ===== Flex helpers ===== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }

/* ===== Entry animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}

.anim-fade-in {
  animation: fadeIn 0.4s ease both;
}
.anim-fade-up {
  animation: fadeInUp 0.4s ease both;
}
.anim-fade-scale {
  animation: fadeInScale 0.35s ease both;
}

/* ===== Interactive ===== */
.tap-scale:active {
  transform: scale(0.97);
  transition: transform 0.15s ease;
}
