/* 全局样式 - 黔行智导小程序 · V20-A 视觉基线 */

page {
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  background: #f5f7f5;
  box-sizing: border-box;
  color: #10251d;
}

/* ===== Color system ===== */
.c-primary { color: #1f8f5f; }
.c-blue { color: #2f6bff; }
.c-orange { color: #e67e22; }
.c-text { color: #10251d; }
.c-gray { color: #4d5f6f; }
.c-hint { color: #909399; }

.bg-primary { background: #1f8f5f; }
.bg-gradient { background: linear-gradient(135deg, #1f8f5f, #2f6bff); }

/* ===== Common card ===== */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #e8edea;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* ===== Page layout ===== */
.page-wrap {
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.page-hd {
  padding: 40rpx 32rpx 24rpx;
}
.page-hd-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #10251d;
  letter-spacing: -0.03em;
}
.page-hd-desc {
  font-size: 28rpx;
  color: #4d5f6f;
  margin-top: 8rpx;
  line-height: 1.6;
}

/* ===== Button styles ===== */
.btn-primary {
  background: linear-gradient(135deg, #1f8f5f, #177a4e);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  padding: 24rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(31,143,95,0.22);
  transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
}
.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.88;
  box-shadow: 0 4rpx 12rpx rgba(31,143,95,0.15);
}

.btn-outline {
  border: 2rpx solid rgba(31,143,95,0.25);
  background: #fff;
  color: #1f8f5f;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s ease, transform 0.15s ease;
}
.btn-outline:active {
  background: rgba(31,143,95,0.06);
  transform: scale(0.97);
}

.btn-ghost {
  background: transparent;
  color: #1f8f5f;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 16rpx 0;
  transition: opacity 0.15s ease;
}
.btn-ghost:active {
  opacity: 0.7;
}

.btn-danger {
  background: transparent;
  color: #ef4444;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid rgba(239,68,68,0.2);
  border-radius: 20rpx;
  padding: 16rpx 48rpx;
  transition: background 0.15s ease;
}
.btn-danger:active {
  background: rgba(239,68,68,0.06);
}

/* ===== Tag styles ===== */
.tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin: 6rpx;
  transition: all 0.2s ease;
}
.tag-active {
  background: rgba(31,143,95,0.1);
  color: #1f8f5f;
  border: 2rpx solid #1f8f5f;
  font-weight: 600;
}
.tag-default {
  background: rgba(255,255,255,0.9);
  color: #4d5f6f;
  border: 2rpx solid #e8edea;
}

/* ===== Page header row with home link ===== */
.page-hd-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.page-hd-left { flex: 1; }
.page-hd-right {
  flex-shrink: 0;
  padding-top: 8rpx;
}
.home-link {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #1f8f5f;
  border: 2rpx solid rgba(31,143,95,0.25);
  border-radius: 20rpx;
  background: rgba(255,255,255,0.85);
}
.home-link--light {
  color: rgba(255,255,255,0.9);
  border-color: rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.12);
}
.home-link--small {
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* ===== Flex helpers ===== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }

/* ===== V20-A: Entry animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes softPulse {
  0%, 100% { box-shadow: 0 8rpx 24rpx rgba(31,143,95,0.22); }
  50%      { box-shadow: 0 8rpx 32rpx rgba(31,143,95,0.35); }
}

.anim-fade-in {
  animation: fadeIn 0.4s ease both;
}
.anim-fade-up {
  animation: fadeInUp 0.4s ease both;
}
.anim-fade-scale {
  animation: fadeInScale 0.35s ease both;
}

/* ===== V20-A: Interactive feedback ===== */
.tap-scale:active {
  transform: scale(0.97);
  transition: transform 0.15s ease;
}
.tap-lift:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 32rpx rgba(16,37,29,0.1);
  transition: all 0.2s ease;
}
.tap-fade:active {
  opacity: 0.75;
  transition: opacity 0.15s ease;
}
