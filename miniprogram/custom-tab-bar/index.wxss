.tab-bar{position:fixed;bottom:0;left:0;width:100%;z-index:50;display:flex;justify-content:space-around;align-items:center;padding:10rpx 40rpx;padding-bottom:calc(10rpx + env(safe-area-inset-bottom));background:#ffffff;border-top:1rpx solid rgba(0,0,0,0.04);box-shadow:0 -2rpx 16rpx rgba(0,0,0,0.03);}
.tab-item{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6rpx 0;color:#94A09A;transition:all 0.2s;position:relative;min-width:100rpx;}
.tab-item.tab-active{color:#012D1D;}
.tab-item.tab-active::after{content:'';position:absolute;bottom:-4rpx;left:50%;transform:translateX(-50%);width:48rpx;height:6rpx;border-radius:3rpx;background:#A8F0C5;}
.tab-icon{width:40rpx;height:40rpx;margin-bottom:4rpx;}
.tab-text{font-size:20rpx;font-weight:500;}
.tab-active .tab-text{font-weight:600;}
