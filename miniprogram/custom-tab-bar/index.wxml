<view class="tab-bar">
  <view class="tab-item {{selected === index ? 'tab-active' : ''}}" wx:for="{{list}}" wx:key="index" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-icon" src="{{selected === index ? item.iconActive : item.icon}}" mode="aspectFit" />
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
