/* pages/scenic-detail/scenic-detail.wxss — V20-D */

/* ===== Page animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Page container ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

.page-container.centered {
  align-items: center;
  justify-content: center;
}

/* ===== Hero section ===== */
.hero-section {
  position: relative;
  padding-top: env(safe-area-inset-top);
  min-height: 380rpx;
}

.hero-deco-orbs {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.hero-orb-1 {
  width: 200rpx; height: 200rpx;
  top: -40rpx; right: -30rpx;
}

.hero-orb-2 {
  width: 120rpx; height: 120rpx;
  bottom: 40rpx; left: -20rpx;
  background: rgba(255,255,255,0.04);
}

.hero-section::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);
  z-index: 0;
}

.hero-overlay {
  display: flex;
  padding: 24rpx 28rpx 40rpx;
  min-height: 380rpx;
  position: relative;
  z-index: 2;
}

.hero-back {
  position: absolute;
  top: 56rpx;
  left: 24rpx;
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  z-index: 10;
}

.back-icon {
  width: 0; height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 16rpx solid rgba(255,255,255,0.9);
}

.hero-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-top: 60rpx;
}

.hero-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.hero-city-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.hero-location-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
  border: 3rpx solid rgba(255,255,255,0.4);
}

.hero-city {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-tag {
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  backdrop-filter: blur(6rpx);
}

.hero-icon-wrap {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-left: 24rpx;
}

.hero-icon {
  width: 100rpx; height: 100rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hero-icon::before {
  content: '';
  width: 0; height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 36rpx solid rgba(255,255,255,0.85);
  transform: translateX(6rpx);
}

.hero-icon::after {
  content: '';
  position: absolute; bottom: 18rpx; right: 20rpx;
  width: 0; height: 0;
  border-left: 11rpx solid transparent;
  border-right: 11rpx solid transparent;
  border-bottom: 24rpx solid rgba(255,255,255,0.55);
}

/* ===== Info sidebar ===== */
.info-sidebar {
  display: flex;
  background: #ffffff;
  margin: -28rpx 28rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  z-index: 5;
  animation: fadeInUp 0.4s 0.1s both;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.info-label {
  font-size: 22rpx;
  color: #9da3b0;
}

.info-divider {
  width: 2rpx;
  height: 48rpx;
  background: #e8eaed;
  align-self: center;
}

/* ===== Content scroll ===== */
.content-scroll {
  flex: 1;
  padding: 20rpx 28rpx 0;
}

/* ===== Section cards ===== */
.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.section-dot {
  width: 12rpx;
  height: 28rpx;
  border-radius: 6rpx;
}

.green-dot { background: #1f8f5f; }
.blue-dot { background: #2f6bff; }
.amber-dot { background: #f59e0b; }

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* Description */
.description-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

/* Highlights */
.highlights-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.highlight-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  flex-shrink: 0;
  margin-top: 10rpx;
}

.highlight-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  flex: 1;
}

/* Tips */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-index {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #fef3c7;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  flex: 1;
}

/* ===== Bottom actions ===== */
.bottom-actions {
  padding: 16rpx 0 20rpx;
}

.ai-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #2f6bff, #1f8f5f);
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(31,143,95,0.3);
}

.ai-btn::after { border: none; }

.ai-btn-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
  box-shadow: 0 0 12rpx rgba(255,255,255,0.4);
}

.ai-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ===== Not found ===== */
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
}

.nf-icon {
  width: 120rpx; height: 120rpx;
  border: 4rpx solid #d0d5dd;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  background: rgba(31,143,95,0.04);
}

.nf-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.nf-desc {
  font-size: 26rpx;
  color: #9da3b0;
  margin-bottom: 36rpx;
}

.nf-back-btn {
  padding: 20rpx 56rpx;
  border-radius: 36rpx;
  background: #1f8f5f;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
}

.nf-back-btn::after { border: none; }

/* ===== Related routes ===== */
.route-dot { background: #e67e22; }

.related-routes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.related-route-card {
  background: #f8faf9;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8f0ec;
}

.related-route-card:active {
  background: #eef5f1;
}

.rr-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.rr-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  line-height: 1.3;
}

.rr-meta {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.rr-meta-text {
  font-size: 22rpx;
  color: #6b7280;
  white-space: nowrap;
}

.rr-meta-divider {
  font-size: 22rpx;
  color: #d0d5dd;
}

.rr-summary {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.rr-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rr-action-text {
  font-size: 26rpx;
  color: #1f8f5f;
  font-weight: 600;
}

.rr-arrow {
  width: 0; height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 10rpx solid #1f8f5f;
}

.rr-empty-text {
  font-size: 26rpx;
  color: #9da3b0;
  line-height: 1.6;
}

/* ===== Bottom spacer ===== */
.list-bottom-spacer {
  height: 60rpx;
}
