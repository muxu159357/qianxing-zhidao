<!-- 景点详情页 -->
<view wx:if="{{attraction}}" class="page-container">
  <!-- 顶部英雄区域 -->
  <view class="hero-section" style="background: {{attraction.imageGradient || 'linear-gradient(135deg, #1f8f5f 0%, #0d5c3a 40%, #2f6bff 100%)'}};">
    <image class="hero-cover-img" src="{{scenicCoverImage}}" mode="aspectFill" />
    <view class="hero-deco-orbs">
      <view class="hero-orb hero-orb-1"></view>
      <view class="hero-orb hero-orb-2"></view>
    </view>
    <view class="hero-overlay">
      <view class="hero-back" bindtap="onGoBack">
        <view class="back-icon"></view>
      </view>
      <view class="hero-content">
        <text class="hero-name">{{attraction.name}}</text>
        <view class="hero-city-row">
          <view class="hero-location-dot"></view>
          <text class="hero-city">{{attraction.city}}</text>
        </view>
        <view class="hero-tags">
          <text wx:for="{{attraction.tags}}" wx:key="*this" class="hero-tag">{{item}}</text>
        </view>
      </view>
      <view class="hero-icon-wrap">
        <view class="hero-icon"></view>
      </view>
    </view>
  </view>

  <!-- 侧边信息栏 -->
  <view class="info-sidebar">
    <view class="info-item">
      <text class="info-value">{{attraction.rating}}</text>
      <text class="info-label">评分</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-value">{{attraction.price || '免费'}}</text>
      <text class="info-label">门票</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-value">{{attraction.duration || '半天'}}</text>
      <text class="info-label">建议时长</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-value">{{attraction.city}}</text>
      <text class="info-label">所在城市</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-scroll" scroll-y="true" enhanced show-scrollbar="{{false}}">
    <!-- 简介 -->
    <view class="section-card" style="animation: fadeInUp 0.4s 0.15s both;">
      <view class="section-header">
        <view class="section-dot green-dot"></view>
        <text class="section-title">景点简介</text>
      </view>
      <text class="description-text">{{attraction.description}}</text>
    </view>

    <!-- 亮点 -->
    <view wx:if="{{attraction.highlights && attraction.highlights.length}}" class="section-card" style="animation: fadeInUp 0.4s 0.2s both;">
      <view class="section-header">
        <view class="section-dot blue-dot"></view>
        <text class="section-title">精彩亮点</text>
      </view>
      <view class="highlights-list">
        <view wx:for="{{attraction.highlights}}" wx:key="*this" class="highlight-item">
          <view class="highlight-dot"></view>
          <text class="highlight-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 包含该景点的路线 -->
    <view wx:if="{{relatedRoutes.length > 0}}" class="section-card" style="animation: fadeInUp 0.4s 0.25s both;">
      <view class="section-header">
        <view class="section-dot route-dot"></view>
        <text class="section-title">包含该景点的路线</text>
      </view>
      <view class="related-routes-list">
        <view wx:for="{{relatedRoutes}}" wx:key="id" class="related-route-card"
              data-route-id="{{item.id}}" bindtap="onTapRelatedRoute">
          <view class="rr-header">
            <text class="rr-name">{{item.name}}</text>
            <view class="rr-meta">
              <text class="rr-meta-text">{{item.days}}天</text>
              <text class="rr-meta-divider">·</text>
              <text class="rr-meta-text">{{item.physicalLevel}}</text>
              <block wx:if="{{item.budgetRange}}">
                <text class="rr-meta-divider">·</text>
                <text class="rr-meta-text">{{item.budgetRange}}</text>
              </block>
            </view>
          </view>
          <text class="rr-summary">{{item.summary}}</text>
          <view class="rr-action">
            <text class="rr-action-text">查看路线</text>
            <view class="rr-arrow"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{attraction && relatedRoutes.length === 0}}" class="section-card" style="animation: fadeInUp 0.4s 0.25s both;">
      <view class="section-header">
        <view class="section-dot route-dot"></view>
        <text class="section-title">包含该景点的路线</text>
      </view>
      <text class="rr-empty-text">暂无包含该景点的推荐路线，你可以返回知识库继续查看其他景点。</text>
    </view>

    <!-- 旅行贴士 -->
    <view wx:if="{{attraction.tips && attraction.tips.length}}" class="section-card" style="animation: fadeInUp 0.4s 0.3s both;">
      <view class="section-header">
        <view class="section-dot amber-dot"></view>
        <text class="section-title">旅行贴士</text>
      </view>
      <view class="tips-list">
        <view wx:for="{{attraction.tips}}" wx:key="*this" class="tip-item">
          <view class="tip-index">{{index + 1}}</view>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions" style="animation: fadeInUp 0.4s 0.35s both;">
      <button class="ai-btn" bindtap="onAskAI">
        <view class="ai-btn-dot"></view>
        <text class="ai-btn-text">询问 AI 伴游</text>
      </button>
    </view>

    <view class="list-bottom-spacer"></view>
  </scroll-view>
</view>

<!-- 加载中 / 未找到 -->
<view wx:else class="page-container centered">
  <view class="not-found">
    <view class="nf-icon"></view>
    <text class="nf-title">景点未找到</text>
    <text class="nf-desc">请检查链接是否正确</text>
    <button class="nf-back-btn" bindtap="onGoBack">返回</button>
  </view>
</view>
