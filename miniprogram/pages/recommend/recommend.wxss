/* 路线推荐页 · V20-B 美化 */

/* ===== Loading ===== */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 80rpx;
}
.loading-dot-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}
.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1f8f5f;
  animation: recDotPulse 1.2s ease-in-out infinite both;
}
.loading-dot:nth-child(2) { animation-delay: 0.15s; background: #2f6bff; }
.loading-dot:nth-child(3) { animation-delay: 0.3s; background: #1f8f5f; }
.loading-dot:nth-child(4) { animation-delay: 0.45s; background: #2f6bff; }

@keyframes recDotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50%      { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: #909399;
  letter-spacing: 0.04em;
}
.loading-sub {
  font-size: 22rpx;
  color: #c0c4cc;
  margin-top: 12rpx;
}

/* ===== Route list ===== */
.route-list {
  padding: 0 32rpx 80rpx;
}

/* ===== Route card ===== */
.route-card {
  position: relative;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.04);
  margin-bottom: 24rpx;
  transition: all 0.25s ease;
  overflow: hidden;
}
.route-card.expanded {
  border-color: rgba(31,143,95,0.2);
  box-shadow: 0 8rpx 36rpx rgba(31,143,95,0.08);
}
.route-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #1f8f5f, #2f6bff);
  border-radius: 22rpx 0 0 22rpx;
  opacity: 0;
  transition: opacity 0.25s ease;
}
.route-card.expanded::before {
  opacity: 1;
}

/* ===== Card header ===== */
.rc-header {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.rc-cover-img {
  width: 140rpx; height: 90rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #d4ede0;
}

/* Rank badge */
.rc-rank {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(31,143,95,0.12), rgba(47,107,255,0.08));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #1f8f5f;
  flex-shrink: 0;
}
.rc-rank.top1 {
  background: linear-gradient(135deg, rgba(230,126,34,0.2), rgba(245,158,11,0.15));
  color: #e67e22;
}

/* Body */
.rc-body {
  flex: 1;
  min-width: 0;
}
.rc-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #10251d;
  letter-spacing: -0.01em;
  line-height: 1.3;
}
.rc-desc {
  font-size: 25rpx;
  color: #909399;
  margin-top: 6rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rc-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.rc-meta .meta-item {
  font-size: 22rpx;
  color: #1f8f5f;
  padding: 4rpx 14rpx;
  background: rgba(31,143,95,0.07);
  border-radius: 8rpx;
  font-weight: 600;
}

.rc-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.rc-tags .tag-mini {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  background: rgba(47,107,255,0.06);
  color: #2f6bff;
  font-weight: 500;
}

/* Score */
.rc-score {
  text-align: center;
  flex-shrink: 0;
  padding-left: 8rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #1f8f5f;
  line-height: 1;
}
.rc-score .score-unit {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
  color: #909399;
  margin-top: 2rpx;
}

/* ===== Timeline (expanded) ===== */
.rc-timeline {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef2f5;
}

.tl-day {
  display: flex;
  gap: 20rpx;
}
.tl-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 36rpx;
  flex-shrink: 0;
}
.tl-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #1f8f5f;
  border: 4rpx solid rgba(31,143,95,0.15);
  box-sizing: border-box;
}
.tl-line {
  width: 3rpx;
  flex: 1;
  min-height: 20rpx;
  background: rgba(31,143,95,0.1);
}
.tl-content {
  padding-bottom: 22rpx;
  flex: 1;
}
.tl-head {
  font-size: 27rpx;
  font-weight: 700;
  color: #10251d;
  margin-bottom: 6rpx;
}
.tl-desc {
  font-size: 24rpx;
  color: #5d6b7a;
  line-height: 1.55;
  margin-bottom: 6rpx;
}
.tl-meta {
  font-size: 20rpx;
  color: #c0c4cc;
}

/* ===== Recommend reason box ===== */
.recommend-reason-box {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(31,143,95,0.03), rgba(47,107,255,0.02));
  border: 1rpx solid rgba(31,143,95,0.08);
}

.recommend-reason-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.recommend-reason-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #1f8f5f;
  flex-shrink: 0;
  min-width: 80rpx;
  padding-top: 2rpx;
}
.recommend-reason-text {
  font-size: 25rpx;
  color: #4d5f6f;
  line-height: 1.6;
  flex: 1;
}

.match-tag-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.match-tag-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #2f6bff;
  flex-shrink: 0;
  min-width: 80rpx;
  padding-top: 2rpx;
}
.match-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}
.match-tag-item {
  font-size: 21rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(47,107,255,0.07);
  color: #2f6bff;
  font-weight: 600;
}

.route-notice-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.route-notice-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #e67e22;
  flex-shrink: 0;
  min-width: 80rpx;
  padding-top: 2rpx;
}
.route-notice-text {
  font-size: 25rpx;
  color: #909399;
  line-height: 1.55;
  flex: 1;
}

/* ===== Detail button ===== */
.rc-detail-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #1f8f5f, #177a4e);
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(31,143,95,0.18);
}
.rc-detail-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ===== Entry animations ===== */
.anim-card-in {
  animation: recFadeUp 0.45s ease both;
}

@keyframes recFadeUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
