<view class="ai-page">
  <!-- Location Modal -->
  <view class="loc-modal-mask" wx:if="{{showLocationModal}}" bindtap="onCloseLocationModal"></view>
  <view class="loc-modal" wx:if="{{showLocationModal}}">
    <view class="loc-modal-title">是否使用当前位置</view>
    <view class="loc-modal-body">使用当前位置后，AI助手可以结合附近景区和当天安排给出更合适的建议。</view>
    <view class="loc-modal-actions">
      <view class="loc-modal-btn loc-btn-cancel" bindtap="onCloseLocationModal">暂不使用</view>
      <view class="loc-modal-btn loc-btn-ok" bindtap="onAllowLocation">使用当前位置</view>
    </view>
  </view>

  <!-- TopAppBar -->
  <view class="top-bar">
    <view class="top-bar-back" bindtap="goBack"></view>
    <view class="top-bar-title">黔行智导</view>
    <view class="top-bar-spacer"></view>
  </view>

  <!-- Chat Area -->
  <scroll-view class="chat-scroll" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation>
    <!-- Timestamp -->
    <view class="chat-time">
      <view class="chat-time-chip">今天 09:41</view>
    </view>

    <view class="msg-list">
      <block wx:for="{{messages}}" wx:key="id">
        <!-- AI Message -->
        <view class="msg-row msg-row-ai" wx:if="{{item.type === 'ai'}}">
          <view class="msg-avatar msg-avatar-ai"></view>
          <view class="msg-wrap">
            <view class="msg-bubble msg-bubble-ai">{{item.content}}</view>
            <view class="msg-actions" wx:if="{{item.actions && item.actions.length > 0}}">
              <view class="msg-action-btn" wx:for="{{item.actions}}" wx:key="label" wx:for-item="action" bindtap="onActionTap" data-action="{{action}}">{{action.label}}</view>
            </view>
          </view>
        </view>
        <!-- User Message -->
        <view class="msg-row msg-row-user" wx:else>
          <view class="msg-bubble msg-bubble-user">{{item.content}}</view>
          <view class="msg-avatar msg-avatar-user">我</view>
        </view>
      </block>

      <!-- Typing indicator -->
      <view class="msg-row msg-row-ai" wx:if="{{isTyping}}">
        <view class="msg-avatar msg-avatar-ai"></view>
        <view class="msg-bubble msg-bubble-typing">
          <view class="dots"><view class="dot" style="animation-delay:0s;"></view><view class="dot" style="animation-delay:0.15s;"></view><view class="dot" style="animation-delay:0.3s;"></view></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Quick Questions -->
  <view class="quick-section" wx:if="{{messages.length === 0}}">
    <scroll-view class="quick-scroll" scroll-x>
      <view class="quick-chip" wx:for="{{quickQuestions}}" wx:key="*this" bindtap="onQuickTap" data-question="{{item}}">{{item}}</view>
    </scroll-view>
  </view>

  <!-- Input Bar -->
  <view class="input-bar">
    <view class="input-wrap">
      <view class="input-add"></view>
      <input class="input-field" placeholder="继续提问..." value="{{inputValue}}" bindinput="onInput" bindconfirm="sendMessage" confirm-type="send" adjust-position="{{false}}" maxlength="300" />
      <view class="input-send {{inputValue ? 'input-send-active' : ''}}" bindtap="sendMessage"></view>
    </view>
  </view>
</view>
