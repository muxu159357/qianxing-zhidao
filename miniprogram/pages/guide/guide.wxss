/* guide.wxss · Stitch 自然科技风 */

.ai-page { min-height:100vh; background:#f8f9fa; display:flex; flex-direction:column; padding-bottom:calc(100rpx + env(safe-area-inset-bottom)); }

/* Header */
.app-header { padding:40rpx 32rpx 12rpx; display:flex; align-items:center; justify-content:space-between; }
.app-header-left { display:flex; flex-direction:column; }
.app-header-title { font-size:44rpx; font-weight:800; color:#012d1d; letter-spacing:2rpx; }
.app-header-sub { font-size:24rpx; color:#414844; margin-top:4rpx; }
.app-header-tag { font-size:22rpx; color:#116c4a; background:#c1ecd4; padding:8rpx 20rpx; border-radius:999rpx; font-weight:500; flex-shrink:0; }

/* Quick questions */
.ai-quick-section { padding:12rpx 24rpx 16rpx; }
.ai-quick-scroll { white-space:nowrap; }
.ai-quick-item { display:inline-block; font-size:24rpx; color:#116c4a; background:#c1ecd4; padding:10rpx 22rpx; border-radius:999rpx; margin-right:12rpx; font-weight:500; }

/* Chat area */
.ai-chat-area { flex:1; padding:0 24rpx; }
.msg-list { display:flex; flex-direction:column; gap:16rpx; padding-bottom:16rpx; }

.msg-row { display:flex; align-items:flex-start; gap:12rpx; }
.msg-ai { flex-direction:row; }
.msg-user { flex-direction:row-reverse; }
.avatar { width:60rpx; height:60rpx; border-radius:50%; flex-shrink:0; }
.avatar-ai { width:60rpx; height:60rpx; }
.avatar-user { background:#116c4a; color:#fff; font-size:22rpx; display:flex; align-items:center; justify-content:center; }
.bubble-wrap { max-width:86%; }
.bubble { font-size:26rpx; line-height:1.6; padding:18rpx 22rpx; border-radius:20rpx; word-break:break-all; }
.bubble-ai { background:#c1ecd4; color:#012d1d; }
.bubble-user { background:#ffffff; color:#012d1d; border:1rpx solid #c1c8c2; }
.bubble-typing { background:#c1ecd4; padding:24rpx 32rpx; }
.dots { display:flex; gap:8rpx; }
.dot { width:12rpx; height:12rpx; border-radius:50%; background:#116c4a; opacity:0.4; animation:pulse 1.4s infinite; }
@keyframes pulse { 0%,60%,100% { opacity:0.4; transform:scale(1); } 30% { opacity:1; transform:scale(1.2); } }

.ai-actions { display:flex; flex-wrap:wrap; gap:10rpx; margin-top:12rpx; }
.ai-action-btn { font-size:22rpx; color:#116c4a; background:rgba(17,108,74,0.08); padding:10rpx 18rpx; border-radius:999rpx; border:1rpx solid rgba(17,108,74,0.16); }

/* Input bar */
.ai-input-bar { position:fixed; bottom:0; left:0; right:0; display:flex; align-items:center; gap:12rpx; padding:16rpx 24rpx; padding-bottom:calc(16rpx + env(safe-area-inset-bottom)); background:#ffffff; border-top:1rpx solid #edeeef; z-index:20; box-shadow:0 -4rpx 20rpx rgba(1,45,29,0.03); }
.ai-input-field { flex:1; height:72rpx; padding:0 24rpx; border-radius:999rpx; background:#f3f4f5; font-size:26rpx; color:#012d1d; }
.ai-send-btn { width:100rpx; height:72rpx; line-height:72rpx; text-align:center; border-radius:999rpx; font-size:26rpx; font-weight:600; color:#8a9ba6; background:#f3f4f5; }
.ai-send-active { background:#012d1d; color:#ffffff; }

/* Location modal */
.location-modal-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:100; }
.location-modal { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); width:580rpx; background:#fff; border-radius:28rpx; padding:48rpx 40rpx 32rpx; z-index:101; box-shadow:0 16rpx 48rpx rgba(0,0,0,0.15); }
.location-modal-title { font-size:34rpx; font-weight:700; color:#012d1d; text-align:center; margin-bottom:20rpx; }
.location-modal-body { font-size:26rpx; color:#414844; line-height:1.7; text-align:center; margin-bottom:36rpx; }
.location-modal-actions { display:flex; gap:20rpx; }
.location-modal-btn { flex:1; height:84rpx; line-height:84rpx; text-align:center; border-radius:999rpx; font-size:28rpx; font-weight:600; }
.location-modal-btn-cancel { background:#f3f4f5; color:#414844; }
.location-modal-btn-ok { background:#012d1d; color:#fff; }
