/* pages/guide/guide.wxss — V20-D */

/* ===== Page animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes typing-bounce {
  0%, 50%, 100% { opacity: 0.25; transform: scale(0.75); }
  25% { opacity: 1; transform: scale(1.15); }
}

/* ===== Page container ===== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== Chat scroll area ===== */
.chat-area {
  flex: 1;
  overflow-y: auto;
  box-sizing: border-box;
}

.msg-list {
  padding: 24rpx 20rpx 4rpx;
  display: flex;
  flex-direction: column;
}

/* ===== Message row ===== */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  animation: fadeInUp 0.3s both;
}

.msg-ai { justify-content: flex-start; }
.msg-user { justify-content: flex-end; }

/* ===== Avatar ===== */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, #1f8f5f, #4caf84);
  box-shadow: 0 0 0 4rpx rgba(31,143,95,0.12);
}

.avatar-user {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  background: linear-gradient(135deg, #ff8c42, #ff6b35);
}

/* ===== Chat bubbles ===== */
.bubble {
  max-width: 68%;
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
  box-sizing: border-box;
}

.bubble-ai {
  background: #ffffff;
  color: #2c3e3a;
  border-top-left-radius: 6rpx;
  margin-left: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.bubble-user {
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  color: #ffffff;
  border-top-right-radius: 6rpx;
  margin-right: 16rpx;
}

/* ===== Typing indicator ===== */
.bubble-typing {
  background: #ffffff;
  padding: 24rpx 32rpx;
  border-top-left-radius: 6rpx;
  margin-left: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a8d5ba;
  animation: typing-bounce 1.2s infinite ease-in-out;
}

/* ===== Quick questions ===== */
.quick-section {
  padding: 20rpx 20rpx 12rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef2ef;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-item {
  padding: 20rpx 16rpx;
  background: #f8faf9;
  border: 1rpx solid #e3ece6;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #1f8f5f;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: background 0.15s;
}

.quick-item:active {
  background: #e8f0eb;
}

.quick-item:nth-child(odd) {
  border-left: 4rpx solid #1f8f5f;
}

.quick-item:nth-child(even) {
  border-left: 4rpx solid #2f6bff;
}

/* ===== Input bar ===== */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: 16rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef2ef;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: #f5f6f8;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.send-btn {
  margin-left: 16rpx;
  padding: 16rpx 30rpx;
  background: #c0c0c0;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.send-btn--active {
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  box-shadow: 0 4rpx 14rpx rgba(31,143,95,0.25);
}

.send-btn--active:active {
  opacity: 0.85;
}
