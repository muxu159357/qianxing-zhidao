/* my-trips.wxss · Stitch 自然科技风 */

.trips-page { min-height:100vh; background:#f8f9fa; display:flex; flex-direction:column; }

/* Header */
.app-header { padding:40rpx 32rpx 12rpx; display:flex; align-items:center; justify-content:space-between; }
.app-header-left { display:flex; flex-direction:column; }
.app-header-title { font-size:44rpx; font-weight:800; color:#012d1d; letter-spacing:2rpx; }
.app-header-sub { font-size:24rpx; color:#414844; margin-top:4rpx; }

/* Stats */
.trips-stats { padding:20rpx 28rpx; }
.trips-stats-row { display:flex; gap:10rpx; background:#ffffff; border-radius:24rpx; padding:24rpx 16rpx; box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05); }
.trips-stat { flex:1; display:flex; flex-direction:column; align-items:center; gap:4rpx; }
.trips-stat-num { font-size:36rpx; font-weight:700; color:#012d1d; }
.trips-stat-label { font-size:20rpx; color:#8a9ba6; }

/* Filter */
.trips-filter { display:flex; padding:12rpx 28rpx 18rpx; gap:12rpx; }
.trips-filter-item { flex:1; text-align:center; padding:14rpx 0; border-radius:999rpx; font-size:26rpx; font-weight:500; color:#414844; background:#f3f4f5; }
.trips-filter-active { color:#012d1d; background:#c1ecd4; font-weight:600; }

/* Trip list */
.trips-list { flex:1; padding:0 28rpx; }
.trip-card { display:flex; align-items:center; background:#ffffff; border-radius:24rpx; margin-bottom:16rpx; overflow:hidden; box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05); }
.trip-card-img { width:200rpx; height:160rpx; position:relative; flex-shrink:0; overflow:hidden; }
.trip-card-img-placeholder { width:100%; height:100%; }
.trip-card-status { position:absolute; top:12rpx; left:12rpx; font-size:20rpx; padding:4rpx 14rpx; border-radius:999rpx; font-weight:500; }
.trip-status-soon { color:#116c4a; background:#c1ecd4; }
.trip-status-active { color:#e67e22; background:rgba(230,126,34,0.15); }
.trip-status-done { color:#414844; background:#edeeef; }
.trip-card-body { flex:1; padding:20rpx; display:flex; flex-direction:column; gap:8rpx; }
.trip-card-name { font-size:28rpx; font-weight:700; color:#012d1d; line-height:1.3; }
.trip-card-meta { font-size:22rpx; color:#8a9ba6; }
.trip-card-tags { display:flex; gap:8rpx; flex-wrap:wrap; }
.trip-card-tag { font-size:20rpx; color:#116c4a; background:#c1ecd4; padding:4rpx 14rpx; border-radius:999rpx; }
.trip-card-delete { width:80rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; align-self:stretch; background:#fef2f2; }
.trip-delete-icon { width:32rpx; height:32rpx; position:relative; }
.trip-delete-icon::before, .trip-delete-icon::after { content:''; position:absolute; top:50%; left:50%; width:24rpx; height:2rpx; background:#ef4444; border-radius:1rpx; }
.trip-delete-icon::before { transform:translate(-50%,-50%) rotate(45deg); }
.trip-delete-icon::after { transform:translate(-50%,-50%) rotate(-45deg); }

/* Empty */
.trips-empty { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:80rpx 60rpx; }
.trips-empty-icon { width:160rpx; height:160rpx; border-radius:50%; background:#f3f4f5; margin-bottom:32rpx; position:relative; }
.trips-empty-icon::before { content:''; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:0; height:0; border-left:24rpx solid transparent; border-right:24rpx solid transparent; border-bottom:40rpx solid #c1c8c2; margin-top:-10rpx; }
.trips-empty-title { font-size:32rpx; font-weight:700; color:#012d1d; margin-bottom:10rpx; }
.trips-empty-desc { font-size:26rpx; color:#8a9ba6; text-align:center; margin-bottom:40rpx; line-height:1.5; }
.primary-button { display:flex; align-items:center; justify-content:center; height:88rpx; line-height:88rpx; border-radius:999rpx; font-size:30rpx; font-weight:700; background:#012d1d; color:#ffffff; border:none; box-shadow:0 8rpx 28rpx rgba(1,45,29,0.2); }
.primary-button:active { transform:scale(0.97); opacity:0.9; }
.primary-button::after { border:none; }

.list-bottom-spacer { height:60rpx; }
