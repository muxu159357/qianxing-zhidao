.trips-page{min-height:100vh;background:#f8f9fa;padding-bottom:160rpx;}
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:0 40rpx;height:128rpx;background:#f8f9fa;position:sticky;top:0;z-index:50;}
.top-bar-back{width:64rpx;height:64rpx;border-radius:50%;position:relative;}
.top-bar-back::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(45deg);width:18rpx;height:18rpx;border-left:3rpx solid #012d1d;border-bottom:3rpx solid #012d1d;}
.top-bar-title{font-size:40rpx;font-weight:700;color:#012d1d;}
.top-bar-spacer{width:64rpx;}
.trips-header{padding:16rpx 40rpx 48rpx;}
.trips-header-title{font-size:56rpx;font-weight:700;color:#012d1d;margin-bottom:8rpx;}
.trips-header-sub{font-size:28rpx;color:#414844;}
.trips-list{padding:0 40rpx;}
.trip-card{margin-bottom:32rpx;background:#ffffff;border-radius:32rpx;overflow:hidden;box-shadow:0 8rpx 40rpx rgba(0,33,20,0.04);}
.trip-card-done{opacity:0.8;}
.trip-card-img{height:384rpx;position:relative;overflow:hidden;}
.trip-card-img image{width:100%;height:100%;}
.trip-status{position:absolute;top:24rpx;left:24rpx;font-size:22rpx;padding:6rpx 20rpx;border-radius:999rpx;font-weight:500;}
.trip-status-upcoming{background:#0f414d;color:#81adbb;}
.trip-status-active{background:rgba(230,126,34,0.15);color:#e67e22;}
.trip-status-done{background:#e7e8e9;color:#414844;}
.trip-card-inner{padding:32rpx;display:flex;flex-direction:column;gap:20rpx;}
.trip-name{font-size:36rpx;font-weight:600;color:#012d1d;}
.trip-date{font-size:24rpx;color:#414844;}
.trip-tags{display:flex;gap:12rpx;flex-wrap:wrap;}
.trip-tag{font-size:22rpx;color:#414844;background:#edeeef;padding:6rpx 20rpx;border-radius:999rpx;}
.trip-card-btn{font-size:26rpx;font-weight:500;color:#fff;background:#116c4a;padding:16rpx 36rpx;border-radius:16rpx;align-self:flex-end;}
.trip-card-done .trip-card-btn{background:transparent;color:#191c1d;border:1rpx solid #c1c8c2;}
.trip-card-delete{position:absolute;top:24rpx;right:24rpx;width:64rpx;height:64rpx;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;}
.trip-card-delete::before,.trip-card-delete::after{content:'';position:absolute;width:24rpx;height:2rpx;background:#ef4444;border-radius:1rpx;}
.trip-card-delete::before{transform:rotate(45deg);}
.trip-card-delete::after{transform:rotate(-45deg);}
.trips-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120rpx 60rpx;}
.trips-empty-icon{width:240rpx;height:240rpx;margin-bottom:40rpx;}
.trips-empty-title{font-size:36rpx;font-weight:700;color:#012d1d;margin-bottom:12rpx;}
.trips-empty-desc{font-size:28rpx;color:#8a9ba6;margin-bottom:48rpx;text-align:center;}
.trips-empty-btn{font-size:30rpx;font-weight:700;color:#fff;background:#012d1d;padding:24rpx 56rpx;border-radius:999rpx;box-shadow:0 8rpx 28rpx rgba(1,45,29,0.2);}
.list-bottom-spacer{height:60rpx;}
