/* pages/my-trips/my-trips.wxss */

/* ===== Page animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(28rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Page container ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== Page header ===== */
.page-header {
  padding: 48rpx 32rpx 36rpx;
  background: linear-gradient(160deg, #1f8f5f 0%, #198056 50%, #14633f 100%);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.5s both;
}

.header-deco {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.header-deco::after {
  content: '';
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.header-wave {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 32rpx;
  background: #f5f6f8;
  border-radius: 50% 50% 0 0;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  line-height: 1.2;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
  position: relative;
  z-index: 1;
}

/* ===== V9: Stats overview ===== */
.stats-section {
  margin: -16rpx 28rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.45s 0.08s both;
}

.stats-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.stats-latest {
  font-size: 22rpx;
  color: #909399;
}

.stats-row {
  display: flex;
  gap: 10rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 6rpx 16rpx;
  border-radius: 14rpx;
  background: #f8faf9;
  position: relative;
  overflow: hidden;
}

.stat-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: #e0e8e3;
}

.stat-item:nth-child(1)::before { background: #909399; }
.stat-item:nth-child(2)::before { background: #1f8f5f; }
.stat-item:nth-child(3)::before { background: #e67e22; }
.stat-item:nth-child(4)::before { background: #2f6bff; }
.stat-item:nth-child(5)::before { background: linear-gradient(90deg, #1f8f5f, #2f6bff); }

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.2;
  margin-top: 6rpx;
}

.stat-num-reviewed {
  color: #1f8f5f;
}

.stat-label {
  font-size: 20rpx;
  color: #909399;
  margin-top: 4rpx;
}

/* ===== Filter bar ===== */
.filter-bar {
  display: flex;
  padding: 20rpx 28rpx;
  background: #ffffff;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  animation: fadeInUp 0.45s 0.12s both;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #5d6b7a;
  background: #f5f6f8;
  transition: all 0.2s;
}

.filter-item-active {
  color: #ffffff;
  background: linear-gradient(135deg, #1f8f5f, #198056);
  box-shadow: 0 4rpx 14rpx rgba(31, 143, 95, 0.22);
}

/* ===== Trip list ===== */
.trips-list {
  flex: 1;
  padding: 20rpx 28rpx 0;
}

.trip-card {
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.trip-card-inner {
  display: flex;
  background: #ffffff;
  position: relative;
  overflow: hidden;
}

.trip-card-accent {
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 0;
  width: 6rpx;
  border-radius: 0 3rpx 3rpx 0;
  background: linear-gradient(180deg, #1f8f5f, #2f6bff);
  z-index: 1;
}

.trip-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 28rpx 22rpx;
  gap: 16rpx;
  background: #ffffff;
}

.trip-main:active {
  background: #f9fafb;
}

.trip-route-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trip-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.trip-route-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.3;
  flex: 1;
  min-width: 0;
}

.trip-status-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.trip-status-upcoming {
  color: #1f8f5f;
  background: rgba(31,143,95,0.08);
}

.trip-status-active {
  color: #e67e22;
  background: rgba(230,126,34,0.1);
}

.trip-status-completed {
  color: #909399;
  background: #f0f2f5;
}

/* Meta tags row */
.trip-meta-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.trip-meta-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #5d6b7a;
  background: #f0f2f5;
}

.trip-energy-easy {
  color: #1f8f5f;
  background: rgba(31, 143, 95, 0.08);
}

.trip-energy-medium {
  color: #e67e22;
  background: rgba(230, 126, 34, 0.08);
}

.trip-energy-hard {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
}

/* Spots row */
.trip-spots-row {
  display: flex;
  align-items: center;
}

.trip-spots-text {
  font-size: 24rpx;
  color: #909399;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Date row */
.trip-date-row {
  display: flex;
  align-items: center;
}

.trip-date-text {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* ===== V7: Review tag ===== */
.trip-review-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.trip-review-done {
  color: #1f8f5f;
  background: rgba(31,143,95,0.08);
}

.trip-review-pending {
  color: #e67e22;
  background: rgba(230,126,34,0.08);
}

.trip-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #c0c4cc;
  border-right: 3rpx solid #c0c4cc;
  transform: rotate(45deg);
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ===== Delete button ===== */
.trip-delete-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  background: linear-gradient(160deg, #ef4444 0%, #dc2626 100%);
  gap: 6rpx;
}

.delete-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}
.delete-icon::before,
.delete-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 3rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 2rpx;
}
.delete-icon::before { transform: translate(-50%, -50%) rotate(45deg); }
.delete-icon::after { transform: translate(-50%, -50%) rotate(-45deg); }

.delete-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ===== Empty state ===== */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
}

.empty-icon {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9da3b0;
  text-align: center;
  margin-bottom: 44rpx;
}

.explore-btn {
  padding: 22rpx 56rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1f8f5f 0%, #2f6bff 100%);
  border: none;
  box-shadow: 0 6rpx 22rpx rgba(31, 143, 95, 0.3);
}

.explore-btn::after {
  border: none;
}

.explore-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ===== Bottom spacer ===== */
.list-bottom-spacer {
  height: 80rpx;
}
