/* pages/my-trips/my-trips.wxss */

/* ===== 页面容器 ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== 页面头部 ===== */
.page-header {
  padding: 40rpx 32rpx 28rpx;
  background: linear-gradient(135deg, #1f8f5f 0%, #198056 100%);
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  line-height: 1.2;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

/* ===== 行程列表 ===== */
.trips-list {
  flex: 1;
  padding: 20rpx 28rpx 0;
}

.trip-card {
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.trip-card-inner {
  display: flex;
  background: #ffffff;
  position: relative;
}

.trip-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  gap: 16rpx;
  background: #ffffff;
  transition: transform 0.2s;
}

.trip-main:active {
  background: #f9fafb;
}

.trip-route-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trip-route-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.3;
}

.trip-meta {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.trip-meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.45;
}

.meta-text {
  font-size: 24rpx;
  color: #6b7280;
}

.trip-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
  flex-shrink: 0;
}

/* ===== 删除按钮 ===== */
.trip-delete-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  gap: 6rpx;
}

.delete-icon {
  width: 40rpx;
  height: 40rpx;
}

.delete-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.25;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9da3b0;
  text-align: center;
  margin-bottom: 44rpx;
}

.explore-btn {
  padding: 22rpx 56rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1f8f5f 0%, #2f6bff 100%);
  border: none;
  box-shadow: 0 6rpx 22rpx rgba(31, 143, 95, 0.3);
}

.explore-btn::after {
  border: none;
}

.explore-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ===== 底部间距 ===== */
.list-bottom-spacer {
  height: 40rpx;
}
