.trips-page{min-height:100vh;background:#F7F8F5;padding-bottom:140rpx;overflow-x:hidden;box-sizing:border-box;}
.trips-page *{box-sizing:border-box;}
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:0 40rpx;height:100rpx;background:#F7F8F5;position:sticky;top:0;z-index:50;}
.top-bar-back{width:64rpx;height:64rpx;border-radius:50%;position:relative;}
.top-bar-back::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(45deg);width:16rpx;height:16rpx;border-left:2rpx solid #012D1D;border-bottom:2rpx solid #012D1D;}
.top-bar-title{font-size:34rpx;font-weight:700;color:#012D1D;letter-spacing:2rpx;}
.top-bar-spacer{width:64rpx;}
.trips-header{padding:16rpx 40rpx 48rpx;}
.trips-header-title{font-size:40rpx;font-weight:700;color:#1F2A24;margin-bottom:8rpx;}
.trips-header-sub{font-size:26rpx;color:#66716B;}
.trips-list{padding:0 40rpx;}
.trip-card{margin-bottom:28rpx;background:#ffffff;border-radius:24rpx;overflow:hidden;box-shadow:0 4rpx 20rpx rgba(1,45,29,0.04);position:relative;}
.trip-card-done{opacity:0.8;}
.trip-card-img{height:300rpx;position:relative;overflow:hidden;}
.trip-card-img image{width:100%;height:100%;}
.trip-status{position:absolute;top:24rpx;left:24rpx;font-size:22rpx;padding:6rpx 20rpx;border-radius:999rpx;font-weight:500;}
.trip-status-upcoming{background:#E8F8F0;color:#116C4A;}
.trip-status-active{background:rgba(230,126,34,0.15);color:#e67e22;}
.trip-status-done{background:#EDEEEF;color:#66716B;}
.trip-card-inner{padding:28rpx;display:flex;flex-direction:column;gap:20rpx;}
.trip-name{font-size:30rpx;font-weight:600;color:#1F2A24;}
.trip-date{font-size:22rpx;color:#66716B;}
.trip-tags{display:flex;gap:12rpx;flex-wrap:wrap;}
.trip-tag{font-size:22rpx;color:#414844;background:#edeeef;padding:6rpx 20rpx;border-radius:999rpx;}
.trip-card-btn{font-size:26rpx;font-weight:500;color:#012D1D;background:#E8F8F0;padding:14rpx 32rpx;border-radius:20rpx;align-self:flex-end;}
.trip-card-done .trip-card-btn{background:transparent;color:#66716B;border:1rpx solid #E1E3E4;}
.trip-card-delete{position:absolute;top:20rpx;right:20rpx;width:52rpx;height:52rpx;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;}
.trip-card-delete::before,.trip-card-delete::after{content:'';position:absolute;width:20rpx;height:2rpx;background:#94A09A;border-radius:1rpx;}
.trip-card-delete::before{transform:rotate(45deg);}
.trip-card-delete::after{transform:rotate(-45deg);}
.trips-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120rpx 60rpx;}
.trips-empty-icon{width:240rpx;height:240rpx;margin-bottom:40rpx;}
.trips-empty-title{font-size:34rpx;font-weight:700;color:#1F2A24;margin-bottom:12rpx;}
.trips-empty-desc{font-size:26rpx;color:#94A09A;margin-bottom:48rpx;text-align:center;}
.trips-empty-btn{font-size:30rpx;font-weight:700;color:#fff;background:#012d1d;padding:24rpx 56rpx;border-radius:999rpx;box-shadow:0 8rpx 28rpx rgba(1,45,29,0.2);}
.list-bottom-spacer{height:60rpx;}
