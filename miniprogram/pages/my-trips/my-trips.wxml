<view class="trips-page">
  <!-- TopAppBar -->
  <view class="top-bar">
    <view class="top-bar-back"></view>
    <view class="top-bar-title">黔行智导</view>
    <view class="top-bar-spacer"></view>
  </view>

  <!-- Header -->
  <view class="trips-header">
    <view class="trips-header-title">我的行程</view>
    <view class="trips-header-sub">管理您在贵州的自然探索之旅</view>
  </view>

  <!-- Trip List -->
  <scroll-view wx:if="{{trips.length > 0}}" class="trips-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="trip-card {{item.status === 'completed' ? 'trip-card-done' : ''}}" wx:for="{{filteredTrips}}" wx:key="id">
      <view class="trip-card-img">
        <image wx:if="{{item.spotNames && item.spotNames.length > 0 && item.spotNames[0].indexOf('荔波') !== -1}}" src="/assets/stitch/trip-libo.jpg" mode="aspectFill" />
        <image wx:elif="{{item.spotNames && item.spotNames.length > 0 && item.spotNames[0].indexOf('梵净') !== -1}}" src="/assets/stitch/trip-fanjingshan.jpg" mode="aspectFill" />
        <image wx:else src="/assets/stitch/trip-libo.jpg" mode="aspectFill" />
        <view class="trip-status {{item.status === 'active' ? 'trip-status-active' : item.status === 'completed' ? 'trip-status-done' : 'trip-status-upcoming'}}">
          {{item.status === 'active' ? '进行中' : item.status === 'completed' ? '已完成' : '即将开始'}}
        </view>
      </view>
      <view class="trip-card-inner">
        <view class="trip-card-content" data-id="{{item.id}}" bindtap="onTapTrip">
          <view class="trip-name">{{item.displayName}}</view>
          <view class="trip-date">{{item.travelDateText || item.savedAt}}</view>
          <view class="trip-tags">
            <view class="trip-tag">{{item.energyLevel === '挑战' ? '徒步' : item.energyLevel === '轻松' ? '休闲' : '适中'}}</view>
            <view class="trip-tag" wx:if="{{item.spotNames && item.spotNames.length > 0}}">{{item.spotNames[0]}}</view>
          </view>
        </view>
        <view class="trip-card-btn" data-id="{{item.id}}" bindtap="onTapTrip">
          {{item.status === 'completed' ? '回顾行程' : '查看详情'}}
        </view>
        <view class="trip-card-delete" data-id="{{item.id}}" bindtap="onDeleteTrip"></view>
      </view>
    </view>
    <view class="list-bottom-spacer"></view>
  </scroll-view>

  <!-- Empty State -->
  <view wx:else class="trips-empty">
    <view class="trips-empty-icon"></view>
    <view class="trips-empty-title">{{emptyTitle}}</view>
    <view class="trips-empty-desc">{{emptyDesc}}</view>
    <view class="trips-empty-btn" bindtap="onGoExplore">去首页看看推荐路线</view>
  </view>
</view>
