/* 兴趣选择页样式 · V20-A 美化 */
.planner-page { background:#f8f9fa; }

/* ===== Plan card with left accent ===== */
.plan-card {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.05);
  border: 1rpx solid #e8edea;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.plan-card-accent {
  width: 6rpx;
  background: linear-gradient(180deg, #012d1d, #116c4a);
  flex-shrink: 0;
  border-radius: 3rpx 0 0 3rpx;
}
.plan-card-body {
  flex: 1;
  padding: 28rpx 28rpx 28rpx 24rpx;
}

.form-section { padding: 0 32rpx; }
.form-label {
  font-size: 30rpx; font-weight: 700; color: #10251d;
  margin-bottom: 20rpx;
}
.required { font-size: 24rpx; color: #e67e22; font-weight: 400; }
.tag-list {
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: 16rpx;
}

/* ===== V20-A: 柔和标签系统 ===== */
.planner-tag {
  padding: 14rpx 28rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  min-width: 120rpx;
  text-align: center;
  box-sizing: border-box;
  transition: all 0.2s ease;
}
.planner-tag--default {
  background: #f0f5f2;
  color: #4d5f6f;
  border: 2rpx solid #e8edea;
}
.planner-tag--default:active {
  background: #e0ebe4;
}
.planner-tag--active {
  background: rgba(1,45,29,0.08);
  color: #012d1d;
  border: 2rpx solid #012d1d;
  font-weight: 600;
}

/* ===== Radio group ===== */
.radio-group {
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: 16rpx;
}
.radio-item {
  padding: 16rpx 28rpx; border-radius: 20rpx; min-width: 120rpx;
  font-size: 28rpx; border: 2rpx solid #e8edea;
  background: #f0f5f2; color: #4d5f6f;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s ease;
}
.radio-item:active {
  background: #e0ebe4;
}
.radio-active {
  border-color: #012d1d;
  background: rgba(1,45,29,0.08);
  color: #012d1d;
  font-weight: 600;
}

/* ===== Submit area ===== */
.submit-area {
  padding: 16rpx 0 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.submit-hint {
  font-size: 24rpx;
  color: #909399;
}
.submit-btn {
  width: 88%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}
