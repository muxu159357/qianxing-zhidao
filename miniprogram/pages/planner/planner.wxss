/* 增强标签选中态 */
.tag-list .tag-active {
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  color: #fff;
  border-color: transparent;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(31,143,95,0.28);
  position: relative;
}
.tag-list .tag-default {
  background: rgba(255,255,255,0.9);
  color: #5d6b7a;
  border: 2rpx solid rgba(31,143,95,0.12);
}

.form-section { padding: 0 32rpx; }
.form-label { font-size: 30rpx; font-weight: 700; color: #10251d; margin-bottom: 20rpx; }
.required { font-size: 24rpx; color: #e67e22; font-weight: 400; }
.tag-list { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; }

.radio-group { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; }
.radio-item {
  padding: 16rpx 28rpx; border-radius: 20rpx; min-width: 120rpx;
  font-size: 28rpx; border: 2rpx solid rgba(31,143,95,0.15);
  background: rgba(255,255,255,0.85); color: #5d6b7a;
  display: flex; align-items: center; justify-content: center;
}
.radio-active {
  border-color: #1f8f5f; background: rgba(31,143,95,0.1);
  color: #1f8f5f; font-weight: 600;
}

.submit-area { padding: 32rpx 0 64rpx; display: flex; justify-content: center; }
.submit-btn { width: 88%; height: 96rpx; display: flex; align-items: center; justify-content: center; }
