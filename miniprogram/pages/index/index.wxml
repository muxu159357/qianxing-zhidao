<view class="home-page">
  <view class="home-hero">
    <view class="home-hero-bg"></view>
    <view class="home-hero-content">
      <image class="home-logo" src="/assets/images/brand/logo.png" mode="aspectFit" />
      <view class="home-brand">黔行智导</view>
      <view class="home-sub">贵州山地旅游 AI 个性化导览平台</view>
      <button class="home-cta" bindtap="goPlanner">开始智能规划</button>
    </view>
  </view>

  <view class="home-quick">
    <view class="home-quick-item" wx:for="{{quickEntries}}" wx:key="key" bindtap="onQuickTap" data-key="{{item.key}}">
      <image class="home-quick-icon" src="{{item.icon}}" mode="aspectFit" />
      <view class="home-quick-title">{{item.title}}</view>
      <view class="home-quick-sub">{{item.sub}}</view>
    </view>
  </view>

  <view class="home-section">
    <view class="home-section-title">探索景区</view>
    <scroll-view class="home-cats" scroll-x>
      <view class="home-cat {{activeCategory===item.key?'home-cat-active':''}}" wx:for="{{categories}}" wx:key="key" bindtap="onCategoryTap" data-key="{{item.key}}">{{item.label}}</view>
    </scroll-view>
    <view class="home-scenic-grid">
      <view class="home-scenic-card" wx:for="{{filteredSpots}}" wx:key="id" bindtap="goScenicDetail" data-id="{{item.id}}">
        <view class="home-scenic-img" style="background:linear-gradient(135deg, rgba(31,143,95,0.3), rgba(47,107,255,0.2));">
          <image class="home-scenic-thumb" src="{{item.coverImage || item.imageUrl || '/assets/images/scenic/scenic-huangguoshu.jpg'}}" mode="aspectFill" />
        </view>
        <view class="home-scenic-info">
          <view class="home-scenic-name">{{item.name}}</view>
          <view class="home-scenic-city">{{item.city}}</view>
          <view class="home-scenic-tags">
            <view class="home-scenic-tag" wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" wx:if="{{index < 2}}">{{t}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="home-section">
    <view class="home-section-title">推荐路线</view>
    <view class="home-route-list">
      <view class="home-route-card" wx:for="{{topRoutes}}" wx:key="index" bindtap="goRouteDetail" data-id="{{item.route.id}}">
        <view class="home-route-left">
          <view class="home-route-thumb" style="background:linear-gradient(135deg, rgba(47,107,255,0.3), rgba(31,143,95,0.2));">
            <image class="home-route-img" src="{{item.coverImage}}" mode="aspectFill" />
          </view>
        </view>
        <view class="home-route-body">
          <view class="home-route-name">{{item.route.name}}</view>
          <view class="home-route-meta">{{item.route.dayCount||item.route.days}}天 · {{item.route.energyLevel||item.route.physicalLevel||'适中'}}</view>
          <view class="home-route-desc">{{item.route.description}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="home-bottom"></view>
</view>
