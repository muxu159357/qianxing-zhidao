<!-- 首页 -->
<view class="page-wrap home-page">
  <view class="hero-section">
    <image class="hero-bg-img" src="/assets/images/home-hero.jpg" mode="aspectFill" />
    <view class="hero-video-mask"></view>
    <view class="hero-content">
      <image class="hero-logo" src="/assets/images/brand/logo.png" mode="aspectFit" />
      <view class="hero-brand">黔行智导</view>
      <view class="hero-subtitle">贵州山地旅游 AI 个性化导览</view>
      <text class="hero-desc">基于游客兴趣画像与智能推荐算法\n为您定制专属贵州旅游路线</text>
      <view class="hero-actions">
        <button class="btn-primary hero-btn" bindtap="goPlanner">开始智能规划</button>
        <button class="btn-outline hero-btn-secondary" bindtap="goKnowledge">浏览景点</button>
      </view>
    </view>
  </view>

  <view class="features">
    <view class="section-title">核心能力</view>
    <view class="feature-grid">
      <view class="feature-card" wx:for="{{features}}" wx:key="title"
        bindtap="onFeatureTap" data-key="{{item.key}}" hover-class="feature-card--active">
        <view class="feature-icon" style="background:{{item.bg}}">{{item.tag}}</view>
        <view class="feature-title">{{item.title}}</view>
        <view class="feature-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="routes-preview">
    <view class="section-title">精选路线</view>
    <view class="route-list">
      <view class="route-preview-card" wx:for="{{topRoutes}}" wx:key="id" bindtap="goRouteDetail" data-id="{{item.id}}">
        <view class="rpc-left">
          <view class="rpc-days">{{item.days}}天</view>
        </view>
        <view class="rpc-body">
          <view class="rpc-name">{{item.name}}</view>
          <view class="rpc-desc">{{item.description}}</view>
          <view class="rpc-tags">
            <text class="tag-mini" wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
          </view>
        </view>
        <view class="rpc-arrow">></view>
      </view>
    </view>
    <button class="btn-outline view-all-btn" bindtap="goPlanner">查看更多路线</button>
  </view>
</view>
