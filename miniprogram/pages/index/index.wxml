<view class="home-page">
  <!-- Location -->
  <view class="location-row">
    <view class="location-dot"></view>
    <view class="location-text">贵州山地旅行</view>
  </view>

  <!-- Hero -->
  <view class="hero-card">
    <image class="hero-bg-img" src="/assets/stitch/home-hero.jpg" mode="aspectFill" />
    <view class="hero-gradient"></view>
    <view class="hero-content">
      <view class="hero-title">探索贵州山水</view>
      <view class="hero-subtitle">用 AI 助手规划适合你的山地行程</view>
      <view class="hero-cta" bindtap="goPlanner">
        <view class="hero-cta-icon"></view>
        <view class="hero-cta-text">开始智能规划</view>
      </view>
    </view>
  </view>

  <!-- Today Suggestions Bento -->
  <view class="bento-row">
    <view class="bento-card">
      <view class="bento-header">
        <view class="bento-icon-cloud"></view>
        <view class="bento-chip bento-chip-blue">适宜</view>
      </view>
      <view class="bento-value">24°C</view>
      <view class="bento-label">多云舒适</view>
    </view>
    <view class="bento-card">
      <view class="bento-header">
        <view class="bento-icon-mountain"></view>
        <view class="bento-chip bento-chip-mint">高海拔</view>
      </view>
      <view class="bento-value">1,200m</view>
      <view class="bento-label">平均海拔</view>
    </view>
  </view>

  <!-- Scenic Spots Horizontal Scroll -->
  <view class="scenic-section">
    <view class="section-header">
      <view class="section-title">景区推荐</view>
      <view class="section-more">查看全部</view>
    </view>
    <scroll-view class="scenic-scroll" scroll-x>
      <view class="scenic-card" wx:for="{{filteredSpots}}" wx:key="id" bindtap="goScenicDetail" data-id="{{item.id}}">
        <view class="scenic-card-img">
          <image src="{{item.coverImage || item.imageUrl || '/assets/stitch/home-waterfall.jpg'}}" mode="aspectFill" />
          <view class="scenic-chip">{{item.category || '景区'}}</view>
        </view>
        <view class="scenic-card-body">
          <view class="scenic-card-name">{{item.name}}</view>
          <view class="scenic-card-time">{{item.duration || '半天'}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Recommended Routes -->
  <view class="route-section">
    <view class="section-title">推荐路线</view>
    <view class="route-list">
      <view class="route-card" wx:for="{{topRoutes}}" wx:key="index" bindtap="goRouteDetail" data-id="{{item.route.id}}">
        <view class="route-card-img">
          <image src="{{item.coverImage || '/assets/stitch/home-route-karst.jpg'}}" mode="aspectFill" />
        </view>
        <view class="route-card-body">
          <view class="route-card-name">{{item.route.name}}</view>
          <view class="route-card-info">
            <view class="route-days">{{item.route.dayCount || item.route.days}}天</view>
            <view class="route-path">{{item.route.startCity || '贵阳'}} → {{item.route.endCity || '安顺'}}</view>
          </view>
        </view>
        <view class="route-arrow"></view>
      </view>
    </view>
  </view>

  <view class="home-bottom"></view>
</view>
