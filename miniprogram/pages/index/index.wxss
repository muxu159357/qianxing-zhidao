.home-page{min-height:100vh;background:#F7F8F5;padding-bottom:140rpx;overflow-x:hidden;box-sizing:border-box;}
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:0 40rpx;height:100rpx;background:#F7F8F5;}
.top-bar-back{width:64rpx;height:64rpx;border-radius:50%;position:relative;}
.top-bar-back::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(45deg);width:16rpx;height:16rpx;border-left:2rpx solid #012D1D;border-bottom:2rpx solid #012D1D;}
.top-bar-title{font-size:34rpx;font-weight:700;color:#012D1D;letter-spacing:2rpx;}
.top-bar-spacer{width:64rpx;}
.location-row{display:flex;align-items:center;gap:8rpx;padding:0 40rpx 28rpx;color:#66716B;font-size:22rpx;}
.location-dot{width:10rpx;height:10rpx;border-radius:50%;background:#A8F0C5;}
.hero-card{position:relative;overflow:hidden;border-radius:24rpx;height:460rpx;margin:0 40rpx 40rpx;box-shadow:0 4rpx 24rpx rgba(1,45,29,0.06);}
.hero-bg-img{position:absolute;top:0;left:0;width:100%;height:100%;}
.hero-gradient{position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(1,45,29,0.9),rgba(1,45,29,0.4),transparent);z-index:1;}
.hero-content{position:relative;z-index:2;display:flex;flex-direction:column;justify-content:flex-end;height:100%;padding:36rpx 36rpx;}
.hero-title{font-size:46rpx;font-weight:700;color:#ffffff;line-height:1.15;margin-bottom:8rpx;}
.hero-subtitle{font-size:26rpx;color:rgba(255,255,255,0.82);line-height:1.4;margin-bottom:28rpx;}
.hero-cta{display:flex;align-items:center;gap:10rpx;background:#012D1D;color:#ffffff;border-radius:999rpx;padding:18rpx 36rpx;width:fit-content;box-shadow:0 4rpx 20rpx rgba(1,45,29,0.18);}
.hero-cta-icon{width:28rpx;height:28rpx;border-radius:50%;background:rgba(168,240,197,0.45);}
.hero-cta-text{font-size:26rpx;font-weight:600;}
.bento-row{display:flex;gap:20rpx;padding:0 40rpx;margin-bottom:40rpx;}
.bento-card{flex:1;background:#ffffff;border-radius:24rpx;padding:28rpx 24rpx;box-shadow:0 4rpx 20rpx rgba(1,45,29,0.04);display:flex;flex-direction:column;justify-content:space-between;min-height:176rpx;}
.bento-header{display:flex;justify-content:space-between;align-items:center;}
.bento-icon-cloud{width:40rpx;height:36rpx;border-radius:50%;background:#bceaf9;}
.bento-icon-mountain{width:36rpx;height:36rpx;border-radius:8rpx;background:#c1ecd4;}
.bento-chip{font-size:20rpx;padding:3rpx 14rpx;border-radius:999rpx;font-weight:500;}
.bento-chip-blue{background:#bceaf9;color:#012d1d;}
.bento-chip-mint{background:#A8F0C5;color:#116C4A;}
.bento-value{font-size:34rpx;font-weight:700;color:#012d1d;margin-top:8rpx;}
.bento-label{font-size:26rpx;color:#66716B;}
.scenic-section{margin-bottom:40rpx;}
.section-header{display:flex;justify-content:space-between;align-items:center;padding:0 40rpx;margin-bottom:24rpx;}
.section-title{font-size:34rpx;font-weight:700;color:#012D1D;}
.section-more{font-size:26rpx;color:#66716B;}
.scenic-scroll{white-space:nowrap;padding:0 40rpx 16rpx;}
.scenic-card{display:inline-block;width:340rpx;margin-right:20rpx;background:#ffffff;border-radius:32rpx;overflow:hidden;box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05);vertical-align:top;}
.scenic-card-img{height:220rpx;overflow:hidden;position:relative;}
.scenic-card-img image{width:100%;height:100%;}
.scenic-chip{position:absolute;top:20rpx;left:20rpx;background:rgba(1,45,29,0.7);color:#fff;font-size:20rpx;padding:4rpx 16rpx;border-radius:999rpx;}
.scenic-card-body{padding:20rpx 22rpx 22rpx;}
.scenic-card-name{font-size:28rpx;font-weight:600;color:#012D1D;margin-bottom:4rpx;white-space:normal;}
.scenic-card-time{font-size:22rpx;color:#66716B;}
.route-section{padding:0 40rpx;margin-bottom:40rpx;}
.route-section .section-title{margin-bottom:24rpx;}
.route-list{display:flex;flex-direction:column;gap:24rpx;}
.route-card{display:flex;align-items:center;gap:20rpx;background:#ffffff;border-radius:24rpx;padding:24rpx;box-shadow:0 4rpx 20rpx rgba(1,45,29,0.05);}
.route-card-img{width:112rpx;height:112rpx;border-radius:20rpx;overflow:hidden;flex-shrink:0;}
.route-card-img image{width:100%;height:100%;}
.route-card-body{flex:1;}
.route-card-name{font-size:28rpx;font-weight:600;color:#012D1D;margin-bottom:6rpx;}
.route-card-info{display:flex;align-items:center;gap:20rpx;}
.route-days{font-size:22rpx;color:#116C4A;background:rgba(168,240,197,0.35);padding:4rpx 14rpx;border-radius:999rpx;}
.route-path{font-size:22rpx;color:#66716B;}
.route-arrow{width:20rpx;height:20rpx;border-top:2rpx solid #94A09A;border-right:2rpx solid #94A09A;transform:rotate(45deg);flex-shrink:0;}
.home-bottom{height:60rpx;}
