<view class="rd-page">
  <view wx:if="{{emptyState}}" class="rd-empty">
    <view class="rd-empty-card">
      <view class="rd-empty-icon"></view>
      <view class="rd-empty-title">暂未找到该路线</view>
      <view class="rd-empty-desc">你可以返回路线推荐页，重新选择适合自己的贵州山地旅行路线。</view>
      <view class="rd-empty-btn" bindtap="onGoRecommend">返回路线推荐</view>
    </view>
  </view>

  <block wx:else>
    <!-- TopAppBar -->
    <view class="top-bar">
      <view class="top-bar-back" bindtap="goHome"></view>
      <view class="top-bar-title">黔行智导</view>
      <view class="top-bar-spacer"></view>
    </view>

    <!-- Hero -->
    <view class="rd-hero">
      <image class="rd-hero-img" src="{{routeCoverImage || '/assets/stitch/route-hero.jpg'}}" mode="aspectFill" binderror="onCoverError"/>
      <view class="rd-hero-mask"></view>
      <view class="rd-hero-content">
        <view class="rd-hero-tags">
          <view class="rd-hero-tag" wx:for="{{route.tags}}" wx:key="*this" wx:if="{{index < 2}}">{{item}}</view>
        </view>
        <view class="rd-hero-name">{{route.name}}</view>
        <view class="rd-hero-desc">{{route.description}}</view>
      </view>
    </view>

    <!-- Stats Grid -->
    <view class="rd-stats">
      <view class="rd-stat">
        <view class="rd-stat-icon rd-stat-icon-days"></view>
        <view class="rd-stat-label">天数</view>
        <view class="rd-stat-value">{{route.days}}天</view>
      </view>
      <view class="rd-stat rd-stat-center">
        <view class="rd-stat-icon rd-stat-icon-level"></view>
        <view class="rd-stat-label">难度</view>
        <view class="rd-stat-value">{{route.physicalLevel}}</view>
      </view>
      <view class="rd-stat">
        <view class="rd-stat-icon rd-stat-icon-star"></view>
        <view class="rd-stat-label">亮点</view>
        <view class="rd-stat-value">{{attractions.length}}个景点</view>
      </view>
    </view>

    <!-- Daily Plan Timeline -->
    <view class="rd-section" wx:if="{{route.dailyPlan && route.dailyPlan.length > 0}}">
      <view class="rd-section-title">每日安排</view>
      <view class="rd-timeline">
        <view class="rd-tl-line"></view>
        <view class="rd-tl-node" wx:for="{{route.dailyPlan}}" wx:key="day" wx:if="{{index < 2}}">
          <view class="rd-tl-dot">D{{item.day}}</view>
          <view class="rd-tl-card">
            <view class="rd-tl-head">{{item.title}}</view>
            <view class="rd-tl-loc">{{item.meals}}</view>
            <view class="rd-tl-desc">{{item.description}}</view>
            <view class="rd-tl-tags">
              <view class="rd-tl-tag" wx:for="{{route.tags}}" wx:key="*this" wx:if="{{index < 2}}">{{item}}</view>
            </view>
          </view>
        </view>
        <view class="rd-tl-node" wx:if="{{route.dailyPlan.length > 2}}">
          <view class="rd-tl-dot rd-tl-dot-more">...</view>
          <view class="rd-tl-expand">
            <view class="rd-tl-expand-text">展开完整{{route.days}}天行程</view>
          </view>
        </view>
      </view>
    </view>

    <!-- Safety Section (condensed) -->
    <view class="rd-section" wx:if="{{safety}}">
      <view class="rd-section-title">安全守护</view>
      <view class="rd-safety">
        <view class="rd-safety-row">
          <view class="rd-safety-label">路线风险等级</view>
          <view class="rd-risk rd-risk-{{safety.riskLevel}}">{{safety.riskLabel}}</view>
        </view>
        <view class="rd-safety-text" wx:if="{{safety.physicalReminder}}">{{safety.physicalReminder}}</view>
      </view>
    </view>

    <!-- Save Button -->
    <view class="rd-save-bar">
      <view class="rd-save-btn" bindtap="onSaveOrViewTrip">
        <view class="rd-save-icon"></view>
        <view class="rd-save-text">{{hasSavedTrip ? '查看我的行程' : '保存到我的行程'}}</view>
      </view>
      <view class="rd-guide-btn" bindtap="onOpenAiGuide">开启 AI 山地伴游</view>
    </view>
  </block>
</view>
