.rd-page{min-height:100vh;background:#f8f9fa;padding-bottom:240rpx;}
.rd-empty{display:flex;align-items:center;justify-content:center;min-height:80vh;padding:48rpx;}
.rd-empty-card{background:#fff;border-radius:32rpx;padding:64rpx 48rpx;text-align:center;box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05);}
.rd-empty-icon{width:88rpx;height:88rpx;border:5rpx solid #116c4a;border-radius:50%;margin:0 auto 24rpx;background:rgba(17,108,74,0.06);}
.rd-empty-title{font-size:36rpx;font-weight:700;color:#012d1d;margin-bottom:16rpx;}
.rd-empty-desc{font-size:28rpx;color:#414844;line-height:1.7;margin-bottom:40rpx;}
.rd-empty-btn{display:inline-block;font-size:30rpx;font-weight:700;color:#fff;background:#012d1d;padding:24rpx 56rpx;border-radius:999rpx;box-shadow:0 8rpx 28rpx rgba(1,45,29,0.2);}
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:0 40rpx;height:128rpx;background:#f8f9fa;position:sticky;top:0;z-index:50;}
.top-bar-back{width:64rpx;height:64rpx;border-radius:50%;position:relative;}
.top-bar-back::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(45deg);width:18rpx;height:18rpx;border-left:3rpx solid #012d1d;border-bottom:3rpx solid #012d1d;}
.top-bar-title{font-size:40rpx;font-weight:700;color:#012d1d;}
.top-bar-spacer{width:64rpx;}
.rd-hero{position:relative;height:512rpx;margin:0 40rpx;border-radius:24rpx;overflow:hidden;}
.rd-hero-img{position:absolute;top:0;left:0;width:100%;height:100%;}
.rd-hero-mask{position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(0,0,0,0.6),transparent);z-index:1;}
.rd-hero-content{position:absolute;bottom:0;left:0;right:0;padding:40rpx;z-index:2;}
.rd-hero-tags{display:flex;gap:12rpx;margin-bottom:16rpx;}
.rd-hero-tag{font-size:22rpx;color:#002a34;background:rgba(161,206,220,0.9);padding:6rpx 20rpx;border-radius:999rpx;}
.rd-hero-name{font-size:48rpx;font-weight:700;color:#ffffff;line-height:1.2;margin-bottom:8rpx;}
.rd-hero-desc{font-size:28rpx;color:rgba(255,255,255,0.85);line-height:1.5;}
.rd-stats{display:flex;gap:20rpx;margin:24rpx 40rpx;padding:32rpx;background:#ffffff;border-radius:24rpx;box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05);}
.rd-stat{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;}
.rd-stat-center{border-left:2rpx solid #edeeef;border-right:2rpx solid #edeeef;}
.rd-stat-icon{width:48rpx;height:48rpx;border-radius:50%;margin-bottom:8rpx;}
.rd-stat-icon-days{background:rgba(17,108,74,0.1);}
.rd-stat-icon-level{background:rgba(17,108,74,0.1);}
.rd-stat-icon-star{background:rgba(17,108,74,0.1);}
.rd-stat-label{font-size:22rpx;color:#414844;text-transform:uppercase;margin-bottom:4rpx;}
.rd-stat-value{font-size:36rpx;font-weight:700;color:#012d1d;}
.rd-section{padding:40rpx 40rpx 0;}
.rd-section-title{font-size:40rpx;font-weight:700;color:#012d1d;margin-bottom:32rpx;}
.rd-timeline{position:relative;padding-left:80rpx;}
.rd-tl-line{position:absolute;left:38rpx;top:8rpx;bottom:8rpx;width:3rpx;background:linear-gradient(to bottom,#a1f4c8,#e7e8e9);border-radius:999rpx;}
.rd-tl-node{position:relative;margin-bottom:48rpx;}
.rd-tl-dot{position:absolute;left:-80rpx;top:0;width:76rpx;height:76rpx;background:#f8f9fa;border:3rpx solid #116c4a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;color:#116c4a;z-index:1;}
.rd-tl-dot-more{border-color:#e7e8e9;color:#414844;}
.rd-tl-card{background:#ffffff;border-radius:24rpx;padding:32rpx;box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05);}
.rd-tl-head{font-size:32rpx;font-weight:600;color:#012d1d;margin-bottom:8rpx;}
.rd-tl-loc{font-size:24rpx;color:#414844;margin-bottom:16rpx;}
.rd-tl-desc{font-size:28rpx;color:#414844;line-height:1.6;margin-bottom:16rpx;}
.rd-tl-tags{display:flex;gap:8rpx;}
.rd-tl-tag{font-size:22rpx;color:#414844;background:#edeeef;padding:4rpx 16rpx;border-radius:999rpx;}
.rd-tl-expand{padding:32rpx;border:2rpx dashed #e7e8e9;border-radius:24rpx;display:flex;justify-content:center;background:#f3f4f5;}
.rd-tl-expand-text{font-size:28rpx;color:#414844;}
.rd-safety{background:#fff;border-radius:28rpx;padding:32rpx;box-shadow:0 8rpx 40rpx rgba(1,45,29,0.05);border:1rpx solid rgba(230,126,34,0.1);}
.rd-safety-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx;}
.rd-safety-label{font-size:28rpx;font-weight:600;color:#012d1d;}
.rd-risk{font-size:24rpx;padding:8rpx 24rpx;border-radius:999rpx;font-weight:600;}
.rd-risk-low{background:#c1ecd4;color:#116c4a;}
.rd-risk-mid{background:rgba(230,126,34,0.1);color:#e67e22;}
.rd-risk-high{background:rgba(239,68,68,0.1);color:#ef4444;}
.rd-safety-text{font-size:26rpx;color:#414844;line-height:1.6;}
.rd-save-bar{position:fixed;bottom:0;left:0;right:0;display:flex;flex-direction:column;gap:16rpx;padding:24rpx 40rpx;padding-bottom:calc(24rpx + 120rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,0.96);z-index:10;border-top:1rpx solid rgba(17,108,74,0.06);}
.rd-save-btn{display:flex;align-items:center;justify-content:center;gap:12rpx;height:96rpx;border-radius:999rpx;background:#012d1d;color:#fff;font-size:30rpx;font-weight:600;box-shadow:0 8rpx 24rpx rgba(1,45,29,0.22);}
.rd-save-icon{width:36rpx;height:36rpx;border-radius:50%;background:rgba(161,244,200,0.4);}
.rd-save-text{font-size:30rpx;font-weight:600;}
.rd-guide-btn{display:flex;align-items:center;justify-content:center;height:80rpx;border-radius:999rpx;background:rgba(17,108,74,0.06);color:#116c4a;font-size:28rpx;font-weight:600;border:2rpx solid rgba(17,108,74,0.18);}
