/* 路线详情页 · V20-B 美化 */

/* ===== Page base ===== */
.page-wrap {
  min-height: 100vh;
  background: #f5f7f5;
  padding-bottom: 180rpx;
}

/* ===== Empty state ===== */
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 48rpx;
}
.empty-card {
  text-align: center;
  padding: 64rpx 48rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 16rpx 48rpx rgba(19,61,45,0.06);
  max-width: 600rpx;
  width: 100%;
}
.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border: 5rpx solid #1f8f5f;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  position: relative;
  background: rgba(31,143,95,0.06);
}
.empty-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 18rpx solid #1f8f5f;
  transform: translate(-50%, -60%) rotate(-90deg);
}
.empty-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1f8f5f;
  transform: translate(4rpx, 6rpx);
}
.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #10251d;
  margin-bottom: 16rpx;
}
.empty-desc {
  font-size: 28rpx;
  color: #5d6b7a;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

/* ===== Hero section ===== */
.route-hero {
  position: relative;
  padding: 56rpx 40rpx 44rpx;
  background: linear-gradient(160deg, #1a7a52 0%, #1f8f5f 30%, #238e6a 60%, #2f6bff 100%);
  color: #fff;
  overflow: hidden;
}

.route-hero-cover {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}

.route-hero-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);
  z-index: 1;
}

.route-hero::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.route-hero::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -20rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.03);
}

.route-hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}
.route-hero-main {
  flex: 1;
}

.route-name {
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: -0.01em;
  margin-bottom: 14rpx;
  line-height: 1.2;
}
.route-desc {
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.route-score {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 32rpx;
  position: relative;
  z-index: 2;
  z-index: 1;
}
.score-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.3);
}
.score-num {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}
.score-unit {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 2rpx;
}
.score-label {
  font-size: 28rpx;
  opacity: 0.9;
  font-weight: 500;
}

/* ===== Info grid ===== */
.info-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 28rpx 28rpx 8rpx;
  margin: -16rpx 28rpx 0;
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.05);
}
.info-item {
  width: 50%;
  padding: 20rpx 12rpx;
  box-sizing: border-box;
}
.info-label {
  font-size: 22rpx;
  color: #8c9ba6;
  margin-bottom: 8rpx;
}
.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #10251d;
}
.info-value-sm {
  font-size: 23rpx;
  line-height: 1.4;
}

/* ===== Tag row ===== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx 32rpx 8rpx;
}
.tag-item {
  font-size: 22rpx;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(31,143,95,0.07);
  color: #1f8f5f;
  font-weight: 600;
}

/* ===== Section ===== */
.section {
  padding: 32rpx 32rpx 0;
}
.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #10251d;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1f8f5f;
  line-height: 1.3;
}
.safety-title {
  border-left-color: #e67e22;
}

/* ===== Timeline ===== */
.timeline {
  padding: 0;
}
.tl-day {
  display: flex;
  gap: 18rpx;
  padding-bottom: 4rpx;
}
.tl-marker {
  width: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.tl-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #1f8f5f;
  margin-top: 8rpx;
  box-shadow: 0 0 0 6rpx rgba(31,143,95,0.1);
}
.tl-line {
  width: 3rpx;
  flex: 1;
  background: rgba(31,143,95,0.14);
  margin-top: 8rpx;
}
.tl-content {
  flex: 1;
  padding: 14rpx 22rpx 26rpx;
  margin-bottom: 8rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(19,61,45,0.04);
}
.tl-head {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a6b48;
  margin-bottom: 8rpx;
}
.tl-desc {
  font-size: 26rpx;
  color: #4d5f6f;
  line-height: 1.65;
  margin-bottom: 10rpx;
}
.tl-meta {
  font-size: 22rpx;
  color: #909399;
}

/* ===== Scenic cards ===== */
.scenic-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.scenic-card {
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(19,61,45,0.04);
  transition: transform 0.15s ease;
}
.scenic-card:active {
  transform: scale(0.985);
}
.scenic-gradient {
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  margin: 10rpx;
}
.scenic-info {
  flex: 1;
  padding: 16rpx 20rpx 16rpx 4rpx;
}
.scenic-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #10251d;
}
.scenic-city {
  font-size: 22rpx;
  color: #8c9ba6;
  margin-top: 6rpx;
}
.scenic-rating {
  font-size: 22rpx;
  color: #e67e22;
  margin-top: 6rpx;
  font-weight: 600;
}
.scenic-arrow {
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #c0c4cc;
  font-weight: 300;
}

/* ===== Tip cards ===== */
.tip-card {
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(19,61,45,0.04);
}
.tip-text {
  font-size: 26rpx;
  color: #4d5f6f;
  line-height: 1.75;
  margin-bottom: 14rpx;
}
.tip-text:last-child {
  margin-bottom: 0;
}
.tip-label {
  font-weight: 700;
  color: #10251d;
}

/* ===== Safety card ===== */
.safety-card {
  padding: 32rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(230,126,34,0.12);
  box-shadow: 0 8rpx 32rpx rgba(230,126,34,0.05);
}

.safety-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
}
.safety-row:first-child {
  padding-top: 0;
}
.safety-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #10251d;
}

.safety-icon {
  flex-shrink: 0;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.safety-icon-risk::before {
  content: '';
  width: 0;
  height: 0;
  border-left: 11rpx solid transparent;
  border-right: 11rpx solid transparent;
  border-bottom: 22rpx solid #e67e22;
}
.safety-icon-weather::before {
  content: '';
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #f59e0b;
}
.safety-icon-mountain::before {
  content: '';
  width: 0;
  height: 0;
  border-left: 11rpx solid transparent;
  border-right: 11rpx solid transparent;
  border-bottom: 20rpx solid #1f8f5f;
}
.safety-icon-mountain::after {
  content: '';
  position: absolute;
  top: 10rpx;
  right: 5rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 14rpx solid #2f6bff;
}
.safety-icon-crowd::before {
  content: '';
  width: 11rpx;
  height: 11rpx;
  border-radius: 50%;
  background: #2f6bff;
  box-shadow: 16rpx 0 0 0 #2f6bff;
}
.safety-icon-time::before {
  content: '';
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  border: 3rpx solid #909399;
  box-sizing: border-box;
}
.safety-icon-time::after {
  content: '';
  position: absolute;
  top: 7rpx;
  left: 50%;
  width: 2rpx;
  height: 9rpx;
  background: #909399;
  transform: translateX(-50%);
}

.safety-text {
  font-size: 26rpx;
  color: #4d5f6f;
  line-height: 1.65;
  flex: 1;
}

.risk-badge {
  font-size: 24rpx;
  padding: 6rpx 22rpx;
  border-radius: 999rpx;
  font-weight: 700;
}
.risk-low {
  background: rgba(31,143,95,0.1);
  color: #1f8f5f;
}
.risk-mid {
  background: rgba(230,126,34,0.1);
  color: #e67e22;
}
.risk-high {
  background: rgba(239,68,68,0.1);
  color: #ef4444;
}

.safety-divider {
  height: 1rpx;
  background: #eef2f5;
  margin: 24rpx 0;
}

.safety-subtitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #10251d;
  margin-bottom: 16rpx;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}
.service-item {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  background: rgba(47,107,255,0.06);
  color: #2f6bff;
  font-weight: 600;
}

.emergency-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.emergency-item {
  flex: 1;
  min-width: 160rpx;
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(239,68,68,0.03);
  text-align: center;
  border: 1rpx solid rgba(239,68,68,0.08);
}
.emergency-label {
  font-size: 22rpx;
  color: #8c9ba6;
  margin-bottom: 6rpx;
}
.emergency-number {
  font-size: 34rpx;
  font-weight: 800;
  color: #ef4444;
  letter-spacing: 0.04em;
}
.emergency-note {
  font-size: 22rpx;
  color: #8c9ba6;
}

.alt-route-box {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: rgba(31,143,95,0.03);
  border: 1rpx solid rgba(31,143,95,0.1);
}
.alt-route-label {
  font-size: 24rpx;
  color: #1f8f5f;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.alt-route-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #10251d;
  margin-bottom: 8rpx;
}
.alt-route-level {
  font-size: 24rpx;
  color: #5d6b7a;
  margin-bottom: 22rpx;
}

/* ===== Bottom bar ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(31,143,95,0.06);
  z-index: 10;
}
.btn-save {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: rgba(31,143,95,0.06);
  color: #1f8f5f;
  border: 2rpx solid rgba(31,143,95,0.18);
  transition: all 0.15s ease;
}
.btn-save:active {
  background: rgba(31,143,95,0.12);
  transform: scale(0.97);
}
.btn-guide {
  flex: 1.2;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(31,143,95,0.22);
  transition: all 0.15s ease;
}
.btn-guide:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ===== General buttons ===== */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1f8f5f, #177a4e);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(31,143,95,0.18);
}
.btn-outline-sm {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: transparent;
  color: #1f8f5f;
  border: 2rpx solid rgba(31,143,95,0.25);
}

/* ===== Recommend explanation ===== */
.explain-card {
  padding: 30rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(19,61,45,0.04);
}
.explain-summary {
  font-size: 28rpx;
  color: #4d5f6f;
  line-height: 1.7;
  display: block;
  margin-bottom: 26rpx;
}
.explain-subtitle {
  font-size: 26rpx;
  font-weight: 700;
  color: #10251d;
  margin-bottom: 16rpx;
  display: block;
}
.explain-match-section {
  margin-bottom: 22rpx;
}
.explain-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.explain-item {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  padding: 10rpx 0;
}
.explain-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f8f5f;
  flex-shrink: 0;
  min-width: 110rpx;
}
.explain-detail {
  font-size: 24rpx;
  color: #5d6b7a;
  line-height: 1.5;
  flex: 1;
}
.explain-notice-section {
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f5;
}
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.notice-item {
  padding: 6rpx 0;
}
.notice-text {
  font-size: 24rpx;
  color: #909399;
  line-height: 1.55;
}

/* weather card */
.weather-card { background: rgba(47,107,255,0.04); border-radius: 20rpx; padding: 24rpx; border: 1rpx solid rgba(47,107,255,0.12); }
.weather-summary { font-size: 26rpx; color: #4d5f6f; line-height: 1.6; margin-bottom: 16rpx; display: block; }
.weather-items { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 16rpx; }
.weather-item { padding: 16rpx 20rpx; background: rgba(255,255,255,0.7); border-radius: 14rpx; }
.weather-item-name { font-size: 26rpx; font-weight: 700; color: #10251d; margin-bottom: 6rpx; }
.weather-item-desc { font-size: 24rpx; color: #2f6bff; font-weight: 600; margin-bottom: 6rpx; }
.weather-item-tips { font-size: 22rpx; color: #8a9bb5; line-height: 1.5; }
.weather-item-tips text { display: block; }
.weather-notice { font-size: 22rpx; color: #8a9bb5; line-height: 1.6; }
.weather-notice text { display: block; margin-bottom: 4rpx; }
.weather-unavailable { font-size: 24rpx; color: #909399; }
.weather-temp { font-size: 36rpx; font-weight: 700; color: #2f6bff; margin-bottom: 8rpx; }
.weather-desc { font-size: 26rpx; color: #4d5f6f; margin-bottom: 6rpx; }
.weather-date { font-size: 22rpx; color: #8a9bb5; }
