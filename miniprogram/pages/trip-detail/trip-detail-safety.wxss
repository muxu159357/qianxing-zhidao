/* ===== 6. Safety alerts ===== */
.safety-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.safety-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.safety-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.safety-icon-energy {
  background: rgba(230,126,34,0.12);
}
.safety-icon-energy::before {
  content: '';
  position: absolute;
  top: 30%;
  left: 50%;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 14rpx solid #e67e22;
  transform: translate(-50%, -50%);
}
.safety-icon-energy::after {
  content: '!';
  position: absolute;
  top: 56%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 16rpx;
  font-weight: 700;
  color: #e67e22;
}

.safety-icon-pace {
  background: rgba(47,107,255,0.1);
}
.safety-icon-pace::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #2f6bff;
  transform: translate(-50%, -50%);
}

.safety-icon-density {
  background: rgba(31,143,95,0.1);
}
.safety-icon-density::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 20%;
  width: 8rpx;
  height: 12rpx;
  border-radius: 2rpx;
  background: #1f8f5f;
  transform: translateY(-50%);
}
.safety-icon-density::after {
  content: '';
  position: absolute;
  top: 50%;
  right: 20%;
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: #1f8f5f;
  transform: translateY(-50%);
}

.safety-icon-weather {
  background: rgba(31,143,95,0.1);
}
.safety-icon-weather::before {
  content: '';
  position: absolute;
  top: 35%;
  left: 50%;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1f8f5f;
  transform: translate(-50%, -50%);
}
.safety-icon-weather::after {
  content: '';
  position: absolute;
  top: 65%;
  left: 50%;
  width: 22rpx;
  height: 10rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: rgba(31,143,95,0.25);
  transform: translate(-50%, -50%);
}

.safety-icon-service {
  background: rgba(47,107,255,0.1);
}
.safety-icon-service::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #2f6bff;
  transform: translate(-50%, -50%);
  box-shadow: 8rpx 0 0 #2f6bff, -8rpx 0 0 #2f6bff;
}

.safety-text {
  flex: 1;
  font-size: 26rpx;
  color: #5d6b7a;
  line-height: 1.6;
}

/* ===== V5: Safety status header ===== */
.safety-status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.safety-status-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.safety-status-progress {
  font-size: 22rpx;
  color: #1f8f5f;
  font-weight: 500;
}

/* ===== V5: Progress bar ===== */
.safety-progress-bar {
  width: 100%;
  height: 10rpx;
  background: #f0f2f5;
  border-radius: 5rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.safety-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1f8f5f, #2f6bff);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

/* ===== V5: Safety alerts list ===== */
.safety-alerts-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

/* ===== V5: Checklist ===== */
.checklist-section {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.checklist-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.checklist-items {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.checklist-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
}

.checklist-item:active {
  background: #f8f9fb;
}

.checklist-item-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.checklist-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d0d5dd;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checklist-box-checked {
  background: #1f8f5f;
  border-color: #1f8f5f;
}

.checklist-box-icon {
  display: block;
  width: 12rpx;
  height: 7rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
  margin-top: -2rpx;
}

.checklist-text {
  font-size: 26rpx;
  color: #5d6b7a;
  line-height: 1.4;
  flex: 1;
}

.checklist-text-checked {
  color: #1f8f5f;
  text-decoration: line-through;
}

/* ===== V5: New alert type icons ===== */
.safety-icon-status {
  background: rgba(31,143,95,0.1);
}
.safety-icon-status::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1f8f5f;
  transform: translate(-50%, -50%);
}

.safety-icon-spot {
  background: rgba(230,126,34,0.1);
}
.safety-icon-spot::before {
  content: '';
  position: absolute;
  top: 40%;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  background: #e67e22;
  transform: translate(-50%, -50%) rotate(45deg);
  border-radius: 3rpx;
}

.weather-card { background:rgba(47,107,255,0.04); border-radius:20rpx; padding:24rpx; border:1rpx solid rgba(47,107,255,0.12); margin-bottom:16rpx; }
.weather-temp { font-size:36rpx; font-weight:700; color:#2f6bff; margin-bottom:8rpx; }
.weather-desc { font-size:26rpx; color:#4d5f6f; margin-bottom:6rpx; }
.weather-date { font-size:22rpx; color:#8a9bb5; }
