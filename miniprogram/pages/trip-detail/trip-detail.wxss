@import './trip-detail-plan.wxss';
@import './trip-detail-safety.wxss';
@import './trip-detail-review.wxss';

/* ===== Page animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Page container ===== */
.page-container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* ===== 1. Hero section ===== */
.hero-section {
  position: relative;
  padding: 60rpx 32rpx 44rpx;
  background: linear-gradient(160deg, #012d1d 0%, #012d1d 50%, #012d1d 100%);
  overflow: hidden;
}

.hero-deco-orbs {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.hero-orb-1 {
  width: 260rpx;
  height: 260rpx;
  top: -80rpx;
  right: -60rpx;
}

.hero-orb-2 {
  width: 160rpx;
  height: 160rpx;
  bottom: 10rpx;
  left: -40rpx;
  background: rgba(255,255,255,0.04);
}

.hero-orb::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.hero-orb-1::after {
  width: 120rpx;
  height: 120rpx;
  bottom: 30rpx;
  left: 40rpx;
}

.hero-orb-2::after {
  width: 70rpx;
  height: 70rpx;
  top: 20rpx;
  right: 20rpx;
}

.hero-back {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 3rpx solid rgba(255,255,255,0.85);
  border-bottom: 3rpx solid rgba(255,255,255,0.85);
  transform: rotate(45deg);
}

.hero-content {
  text-align: center;
  position: relative;
  z-index: 1;
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.hero-status {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.trip-status-upcoming {
  color: #ffffff;
  background: rgba(255,255,255,0.2);
}

.trip-status-active {
  color: #ffffff;
  background: rgba(255,165,0,0.3);
}

.trip-status-completed {
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.12);
}

.hero-edit-btn {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  border: 1rpx solid rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.hero-edit-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.hero-edit-input {
  flex: 1;
  max-width: 400rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.hero-edit-confirm {
  padding: 10rpx 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(255,255,255,0.25);
  flex-shrink: 0;
}

.hero-edit-cancel {
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  flex-shrink: 0;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
  display: block;
}

/* ===== 2. Info bar ===== */
.info-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 24rpx 32rpx;
  margin: -12rpx 24rpx 0;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 2;
}

.info-tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #414844;
  background: #e1e3e4;
}

.info-tag-easy {
  color: #012d1d;
  background: rgba(1,45,29,0.08);
}

.info-tag-medium {
  color: #e67e22;
  background: rgba(230,126,34,0.08);
}

.info-tag-hard {
  color: #ef4444;
  background: rgba(239,68,68,0.08);
}

.info-date {
  font-size: 22rpx;
  color: #c0c4cc;
  margin-left: auto;
}

/* ===== Date bar ===== */
.date-bar {
  padding: 0 32rpx 16rpx;
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 0 0 18rpx 18rpx;
}

.date-bar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-bar-label {
  font-size: 24rpx;
  color: #414844;
}

.date-bar-action {
  font-size: 24rpx;
  color: #012d1d;
  padding: 6rpx 12rpx;
}

/* ===== 3. Actions row ===== */
.actions-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  margin: 12rpx 24rpx 0;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn-outline {
  border: 2rpx solid rgba(1,45,29,0.25);
  color: #012d1d;
  background: #ffffff;
}

.action-btn-outline:active {
  background: rgba(1,45,29,0.04);
}

.action-btn-primary {
  background: linear-gradient(135deg, #012d1d, #116c4a);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(1,45,29,0.25);
}

.action-btn-primary:active {
  opacity: 0.85;
}

/* ===== 5. Spots row ===== */
.spots-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.spot-chip {
  display: inline-block;
  padding: 12rpx 22rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #012d1d;
  background: rgba(1,45,29,0.06);
  border: 1rpx solid rgba(1,45,29,0.12);
}

.spot-chip:active {
  background: rgba(1,45,29,0.12);
  transform: scale(0.96);
}

/* ===== Status hint ===== */
.status-hint {
  display: flex;
  justify-content: center;
  padding: 20rpx 28rpx;
}

.status-hint-text {
  font-size: 26rpx;
  color: #8a9ba6;
  text-align: center;
  line-height: 1.5;
}

/* ===== Delete section ===== */
.delete-section {
  margin: 20rpx 24rpx;
  display: flex;
  justify-content: center;
}

.delete-btn {
  padding: 18rpx 52rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(239,68,68,0.2);
  color: #ef4444;
  font-size: 26rpx;
}

.delete-btn:active {
  background: rgba(239,68,68,0.06);
}

/* ===== 7. Bottom spacer ===== */
.bottom-spacer {
  height: 80rpx;
}

/* ===== Empty state ===== */
.empty-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f8f9fa;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
}

.empty-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(1,45,29,0.06);
  border: 3rpx dashed rgba(1,45,29,0.18);
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9da3b0;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.empty-back-btn {
  padding: 22rpx 56rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #012d1d 0%, #116c4a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
