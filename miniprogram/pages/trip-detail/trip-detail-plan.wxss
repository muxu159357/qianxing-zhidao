/* ===== 4. Daily plan timeline ===== */
.section {
  margin: 20rpx 24rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.timeline {
  padding-left: 8rpx;
}

.tl-day {
  display: flex;
  gap: 16rpx;
}

.tl-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
  flex-shrink: 0;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1f8f5f;
  flex-shrink: 0;
}

.tl-line {
  width: 2rpx;
  flex: 1;
  background: rgba(31,143,95,0.18);
  margin: 6rpx 0;
}

.tl-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.tl-day:last-child .tl-content {
  padding-bottom: 0;
}

.tl-head {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
}

.tl-head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.tl-head-row .tl-head {
  flex: 1;
}

.tl-head-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.tl-edit-btn {
  font-size: 22rpx;
  color: #1f8f5f;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(31,143,95,0.25);
  flex-shrink: 0;
}

.tl-edit-btn:active {
  background: rgba(31,143,95,0.06);
}

.tl-edited-tag {
  font-size: 20rpx;
  color: #909399;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: #f0f2f5;
  flex-shrink: 0;
}

.tl-desc {
  font-size: 26rpx;
  color: #5d6b7a;
  margin-top: 6rpx;
  line-height: 1.6;
}

.tl-meta {
  font-size: 22rpx;
  color: #909399;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ===== Day plan edit card ===== */
.tl-edit-card {
  background: #f8f9fb;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tl-edit-head {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.tl-edit-field {
  margin-bottom: 18rpx;
}

.tl-edit-label {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 8rpx;
}

.tl-edit-input {
  width: 100%;
  height: 72rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  border: 1rpx solid #e8e8e8;
  box-sizing: border-box;
}

.tl-edit-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  border: 1rpx solid #e8e8e8;
  box-sizing: border-box;
}

.tl-edit-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}

.tl-edit-confirm {
  padding: 14rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
}

.tl-edit-confirm:active {
  opacity: 0.85;
}

.tl-edit-cancel {
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #909399;
  background: #ffffff;
  border: 1rpx solid #e8e8e8;
}

.tl-edit-cancel:active {
  background: #f5f6f8;
}

.tl-edit-restore {
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #e67e22;
  background: rgba(230,126,34,0.06);
  margin-right: auto;
}

.tl-edit-restore:active {
  background: rgba(230,126,34,0.12);
}
