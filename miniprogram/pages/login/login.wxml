<view class="login-page">
  <view class="login-hero">
    <view class="login-logo">
      <image class="logo-img" src="/assets/images/brand/logo.png" mode="aspectFit" />
    </view>
    <view class="login-title">黔行智导</view>
    <view class="login-subtitle">贵州山地旅游 AI 个性化导览平台</view>
  </view>

  <view class="login-body">
    <view class="login-desc">
      请先完成微信授权登录，以便保存行程、同步路线和使用个性化服务。
    </view>

    <view class="login-features">
      <view class="feature-item">
        <view class="feature-dot"></view>
        <text>获取个性化路线推荐与行程规划</text>
      </view>
      <view class="feature-item">
        <view class="feature-dot"></view>
        <text>保存和管理我的行程</text>
      </view>
      <view class="feature-item">
        <view class="feature-dot"></view>
        <text>使用 AI 伴游功能</text>
      </view>
    </view>

    <button
      class="login-btn {{loading ? 'login-btn--loading' : ''}}"
      bindtap="handleLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '微信授权登录'}}
    </button>

    <view class="login-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <view class="login-footer">登录后可使用路线规划、我的行程与个性化推荐</view>
    <view class="login-skip" bindtap="handleSkip">先看看，稍后登录</view>
  </view>
</view>
