.login-page {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 48rpx;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(31, 143, 95, 0.18);
}

.logo-img {
  width: 100%;
  height: 100%;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #10251d;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #5d6b7a;
  text-align: center;
  line-height: 1.5;
}

.login-body {
  width: 100%;
  max-width: 560rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #4d5f6f;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.login-features {
  margin-bottom: 48rpx;
  padding: 0 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #4d5f6f;
}

.feature-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #1f8f5f, #2f6bff);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(31, 143, 95, 0.3);
  margin-bottom: 20rpx;
}

.login-btn--loading {
  opacity: 0.7;
}

.login-btn::after {
  border: none;
}

.login-error {
  font-size: 26rpx;
  color: #e67e22;
  text-align: center;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.login-footer {
  font-size: 24rpx;
  color: #8a9bb5;
  text-align: center;
  line-height: 1.5;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.login-skip { text-align:center; font-size:28rpx; color:#2f6bff; padding:32rpx 0 80rpx; }
