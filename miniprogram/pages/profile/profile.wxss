/* 游客画像页 · V20-B 美化 */

/* ===== Loading ===== */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 80rpx;
}
.loading-dot-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}
.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #012d1d;
  animation: profileDotPulse 1.2s ease-in-out infinite both;
}
.loading-dot:nth-child(2) { animation-delay: 0.15s; background: #116c4a; }
.loading-dot:nth-child(3) { animation-delay: 0.3s; background: #012d1d; }
.loading-dot:nth-child(4) { animation-delay: 0.45s; background: #116c4a; }

@keyframes profileDotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50%      { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: #8a9ba6;
  letter-spacing: 0.04em;
}
.loading-sub {
  font-size: 22rpx;
  color: #c0c4cc;
  margin-top: 12rpx;
}

/* ===== Content wrapper ===== */
.profile-content {
  padding: 0 32rpx 80rpx;
}

/* ===== Hero card ===== */
.profile-hero {
  position: relative;
  overflow: hidden;
  text-align: center;
  padding: 40rpx 36rpx 36rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(16,37,29,0.06);
  margin-bottom: 28rpx;
}
.profile-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #012d1d, #116c4a, #e67e22);
  border-radius: 24rpx 24rpx 0 0;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  color: #116c4a;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 16rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(17,108,74,0.06);
  border: 1rpx solid rgba(17,108,74,0.1);
}

.profile-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #012d1d;
  letter-spacing: -0.02em;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.profile-summary {
  font-size: 28rpx;
  color: #414844;
  line-height: 1.7;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}
.profile-tags .tag-active {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(1,45,29,0.08);
  color: #012d1d;
  border: 1rpx solid rgba(1,45,29,0.15);
  font-weight: 600;
}

/* ===== Match section ===== */
.match-section-card {
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.04);
  margin-bottom: 28rpx;
}
.section-label {
  font-size: 30rpx;
  font-weight: 800;
  color: #012d1d;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #012d1d;
}

.match-item {
  margin-bottom: 28rpx;
}
.match-item:last-child {
  margin-bottom: 0;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.match-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #012d1d;
}
.match-score {
  font-size: 34rpx;
  font-weight: 800;
  color: #012d1d;
}

.match-bar {
  height: 14rpx;
  background: #edeeef;
  border-radius: 7rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.match-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #012d1d, #34d399);
  transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.match-bar-fill.high {
  background: linear-gradient(90deg, #012d1d, #34d399);
}
.match-bar-fill.mid {
  background: linear-gradient(90deg, #e67e22, #f59e0b);
}
.match-bar-fill.low {
  background: linear-gradient(90deg, #116c4a, #818cf8);
}

.match-reason {
  font-size: 24rpx;
  color: #8a9ba6;
  line-height: 1.5;
}

/* ===== Info section ===== */
.info-card {
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.04);
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f3f1;
}
.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.info-label {
  font-size: 28rpx;
  color: #414844;
}
.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #012d1d;
  text-align: right;
}

/* ===== Style section ===== */
.style-card {
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(16,37,29,0.04);
  margin-bottom: 40rpx;
}

.style-badge {
  display: inline-block;
  padding: 14rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(1,45,29,0.08), rgba(17,108,74,0.06));
  border: 1rpx solid rgba(1,45,29,0.12);
  font-size: 34rpx;
  font-weight: 800;
  color: #012d1d;
  margin-bottom: 16rpx;
}
.style-desc {
  font-size: 27rpx;
  color: #414844;
  line-height: 1.7;
}

/* ===== Actions ===== */
.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 0 0 64rpx;
}
.action-btn {
  width: 88%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #012d1d, #012d1d);
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(1,45,29,0.2);
}
.action-btn:active {
  transform: scale(0.97);
  opacity: 0.88;
}
.action-btn-secondary {
  width: 88%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #ffffff;
  color: #012d1d;
  border: 2rpx solid rgba(1,45,29,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-btn-secondary:active {
  background: rgba(1,45,29,0.04);
}

/* ===== Entry animations ===== */
.anim-hero-in {
  animation: fadeInUp 0.5s ease both;
}
.anim-match-in {
  animation: fadeInUp 0.5s 0.1s ease both;
}
.anim-info-in {
  animation: fadeInUp 0.5s 0.2s ease both;
}
.anim-style-in {
  animation: fadeInUp 0.5s 0.3s ease both;
}
.anim-actions-in {
  animation: fadeInUp 0.5s 0.4s ease both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
