.profile-content { padding: 0 32rpx; }
.loading-box { text-align: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: #909399; }

.profile-hero { text-align: center; }
.hero-badge { display: inline-block; font-size: 24rpx; font-weight: 700; color: #2f6bff; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12rpx; }
.profile-name { font-size: 44rpx; font-weight: 800; color: #10251d; margin-bottom: 16rpx; }
.profile-summary { font-size: 26rpx; color: #5d6b7a; line-height: 1.6; margin-bottom: 20rpx; }
.profile-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 12rpx; }

.match-item { margin-bottom: 24rpx; }
.match-header { display: flex; justify-content: space-between; align-items: center; }
.match-name { font-size: 28rpx; font-weight: 600; color: #10251d; }
.match-score { font-size: 32rpx; font-weight: 800; color: #1f8f5f; }
.match-reason { font-size: 24rpx; color: #909399; margin-top: 6rpx; }

.progress-bar { height: 12rpx; background: #eef2f5; border-radius: 6rpx; margin: 10rpx 0; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #1f8f5f, #2f6bff); border-radius: 6rpx; transition: width 0.6s; }

.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1px solid #eef2f5; }
.info-label { font-size: 26rpx; color: #5d6b7a; }
.info-value { font-size: 26rpx; font-weight: 600; color: #10251d; }

.style-badge { display: inline-block; padding: 12rpx 32rpx; border-radius: 20rpx; background: rgba(31,143,95,0.1); border: 1px solid rgba(31,143,95,0.15); font-size: 32rpx; font-weight: 800; color: #1f8f5f; }
.style-desc { font-size: 26rpx; color: #5d6b7a; margin-top: 12rpx; line-height: 1.6; }

.actions { padding: 32rpx 0 64rpx; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.action-btn { width: 88%; height: 96rpx; display: flex; align-items: center; justify-content: center; }
.action-btn-secondary { width: 88%; height: 88rpx; display: flex; align-items: center; justify-content: center; }
