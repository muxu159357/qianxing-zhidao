.preview-page{min-height:100vh;background:#f4f8f5;padding:24rpx 24rpx 120rpx}
.preview-loading{display:flex;justify-content:center;padding-top:200rpx}
.preview-loading-text{font-size:28rpx;color:#5d6b7a}
.preview-error{font-size:28rpx;color:#e67e22;text-align:center;padding-top:200rpx;margin-bottom:24rpx}
.preview-hero{background:#fff;border-radius:20rpx;padding:28rpx;margin-bottom:24rpx}
.preview-title{font-size:36rpx;font-weight:700;color:#10251d;margin-bottom:12rpx}
.preview-summary{font-size:26rpx;color:#4d5f6f;line-height:1.5;margin-bottom:12rpx}
.preview-meta{font-size:22rpx;color:#e67e22}
.preview-section{background:#fff;border-radius:20rpx;padding:24rpx;margin-bottom:20rpx}
.preview-section-title{font-size:28rpx;font-weight:600;color:#10251d;margin-bottom:16rpx}
.preview-day{margin-bottom:20rpx}
.preview-day-header{font-size:26rpx;font-weight:600;color:#1f8f5f;margin-bottom:12rpx}
.preview-day-item{display:flex;gap:16rpx;margin-bottom:12rpx}
.preview-day-time{width:80rpx;font-size:24rpx;color:#8a9bb5;flex-shrink:0}
.preview-day-body{flex:1}
.preview-day-title{font-size:26rpx;color:#10251d;font-weight:500;margin-bottom:4rpx}
.preview-day-desc{font-size:24rpx;color:#5d6b7a;line-height:1.4}
.preview-actions{display:flex;flex-direction:column;gap:16rpx;margin-top:24rpx}
.preview-btn{width:100%;height:88rpx;line-height:88rpx;text-align:center;border-radius:44rpx;font-size:30rpx;font-weight:600}
.preview-btn-primary{background:linear-gradient(135deg,#1f8f5f,#2f6bff);color:#fff}
.preview-btn-outline{background:rgba(31,143,95,0.08);color:#1f8f5f;border:1rpx solid rgba(31,143,95,0.2)}
.preview-btn-ghost{background:transparent;color:#5d6b7a}
