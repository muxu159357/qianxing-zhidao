/* pages/knowledge/knowledge.wxss */

/* ===== 页面容器 ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== 页面头部 ===== */
.page-header {
  padding: 40rpx 32rpx 20rpx;
  background: linear-gradient(135deg, #1f8f5f 0%, #198056 100%);
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  line-height: 1.2;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

/* ===== 搜索栏 ===== */
.search-section {
  padding: 24rpx 28rpx;
  background: #ffffff;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f6f8;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 76rpx;
  border: 2rpx solid #e8eaed;
  transition: border-color 0.2s;
}

.search-box:focus-within {
  border-color: #1f8f5f;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.45;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  margin: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
}

.search-placeholder {
  color: #9da3b0;
}

.clear-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.4;
  flex-shrink: 0;
}

/* ===== 分类标签 ===== */
.category-tabs {
  background: #ffffff;
  padding-bottom: 8rpx;
  white-space: nowrap;
}

.tabs-wrapper {
  display: flex;
  padding: 0 28rpx;
  gap: 8rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
  transition: color 0.2s;
}

.tab-active .tab-text {
  color: #1f8f5f;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #1f8f5f;
}

/* ===== 知识列表 ===== */
.knowledge-list {
  flex: 1;
  padding: 16rpx 28rpx 0;
}

.knowledge-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.25s;
}

.knowledge-card:active {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  gap: 16rpx;
}

.card-question-row {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 16rpx;
}

.card-category-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}

/* 分类颜色 */
.card-category-dot.scenic { background: #2f6bff; }
.card-category-dot.transport { background: #f59e0b; }
.card-category-dot.food { background: #ef4444; }
.card-category-dot.culture { background: #8b5cf6; }
.card-category-dot.tips { background: #1f8f5f; }

.card-question {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
  flex: 1;
}

.card-arrow {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.35;
  flex-shrink: 0;
  transition: transform 0.25s ease;
}

.arrow-expanded {
  transform: rotate(180deg);
  opacity: 0.55;
}

/* 卡片答案 */
.card-answer {
  padding: 0 28rpx 28rpx;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.answer-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.75;
  display: block;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border-left: 6rpx solid #1f8f5f;
}

.answer-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #2f6bff 0%, #1f8f5f 100%);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

.action-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #6b7280;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9da3b0;
  text-align: center;
}

/* ===== 底部间距 ===== */
.list-bottom-spacer {
  height: 40rpx;
}
