/* pages/knowledge/knowledge.wxss — V20-D */

/* ===== Page animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Page container ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== Page header ===== */
.page-header {
  padding: 48rpx 32rpx 36rpx;
  background: linear-gradient(160deg, #1f8f5f 0%, #198056 50%, #14633f 100%);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.5s both;
}

.header-deco {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.header-deco::after {
  content: '';
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.header-wave {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 32rpx;
  background: #f5f6f8;
  border-radius: 50% 50% 0 0;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  line-height: 1.2;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
  position: relative;
  z-index: 1;
}

/* ===== Search bar ===== */
.search-section {
  padding: 24rpx 28rpx;
  background: #ffffff;
  animation: fadeInUp 0.4s 0.08s both;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f6f8;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 76rpx;
  border: 2rpx solid #e8eaed;
  transition: border-color 0.2s;
}

.search-box:focus-within {
  border-color: #1f8f5f;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.45;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  margin: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
}

.search-placeholder { color: #9da3b0; }

.clear-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  position: relative;
  opacity: 0.5;
}
.clear-icon::before,
.clear-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 18rpx; height: 2rpx;
  background: #9da3b0;
  border-radius: 1rpx;
}
.clear-icon::before { transform: translate(-50%, -50%) rotate(45deg); }
.clear-icon::after { transform: translate(-50%, -50%) rotate(-45deg); }

/* ===== Category tabs ===== */
.category-tabs {
  background: #ffffff;
  padding-bottom: 12rpx;
  white-space: nowrap;
  animation: fadeInUp 0.4s 0.12s both;
}

.tabs-wrapper {
  display: flex;
  padding: 0 28rpx;
  gap: 8rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 24rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
  transition: color 0.2s;
}

.tab-active .tab-text {
  color: #1f8f5f;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(90deg, #1f8f5f, #2f6bff);
}

/* ===== Knowledge list ===== */
.knowledge-list {
  flex: 1;
  padding: 16rpx 28rpx 0;
}

.knowledge-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  position: relative;
}

.card-accent {
  position: absolute;
  top: 28rpx;
  bottom: 28rpx;
  left: 0;
  width: 5rpx;
  border-radius: 0 3rpx 3rpx 0;
  background: linear-gradient(180deg, #1f8f5f, #2f6bff);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 28rpx 22rpx;
  gap: 16rpx;
}

.card-question-row {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 16rpx;
}

.card-category-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.card-category-dot.scenic { background: #2f6bff; }
.card-category-dot.transport { background: #f59e0b; }
.card-category-dot.food { background: #ef4444; }
.card-category-dot.culture { background: #8b5cf6; }
.card-category-dot.tips { background: #1f8f5f; }

.card-question {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
  flex: 1;
}

.card-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #9da3b0;
  border-bottom: 3rpx solid #9da3b0;
  transform: rotate(-45deg);
  flex-shrink: 0;
}

.arrow-expanded {
  transform: rotate(135deg);
}

/* Card answer */
.card-answer {
  padding: 0 28rpx 28rpx;
  animation: fadeIn 0.25s ease;
}

.answer-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.75;
  display: block;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 14rpx;
  border-left: 6rpx solid #1f8f5f;
}

.answer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #2f6bff, #1f8f5f);
}

.action-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
}

.action-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.action-btn-scenic {
  background: rgba(31,143,95,0.08);
}

.action-dot-scenic {
  background: #1f8f5f;
}

.action-text-scenic {
  color: #1f8f5f;
}

/* ===== Empty state ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(31,143,95,0.06);
  margin: 0 auto 24rpx;
  position: relative;
}
.empty-icon::before {
  content: '';
  position: absolute;
  top: 34rpx; left: 34rpx;
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  border: 5rpx solid #1f8f5f;
}
.empty-icon::after {
  content: '';
  position: absolute;
  bottom: 34rpx; right: 34rpx;
  width: 22rpx; height: 5rpx;
  border-radius: 3rpx;
  background: #1f8f5f;
  transform: rotate(-45deg);
  transform-origin: right center;
}

.empty-title {
  font-size: 32rpx;
  color: #6b7280;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9da3b0;
  text-align: center;
}

/* ===== Bottom spacer ===== */
.list-bottom-spacer {
  height: 40rpx;
}
